TITLE DataLaborEvent2026v1
FAMILY DataLaborEvent
VERSION 1.0.0
CATEGORY DATA_LABOR
SUMMARY Canonical ALN particle for treating AI chat and dataset curation as paid labor with neuroright corridors.

meta
  ownerrepo        string   eco_restoration_shard
  ownerroleband    string   GOV
  signingdid       string   bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
  spechashhex      hex64    0xa1b2c3d4e5f67890
  kerlane          string   RESEARCH,PILOT,PROD
endmeta

enum LaborSourceKind
  HUMAN_CHAT_SESSION        ; natural‑language chat, human primary
  HUMAN_DATA_UPLOAD         ; manual CSV/JSON upload by human
  SENSOR_STREAM_AGGREGATE   ; IoT or biosensor aggregation (non‑identifying)
  DERIVED_FEATURE_VECTOR    ; ML‑derived embeddings/features
  CURATION_REVIEW_DECISION  ; accept/reject/label events
  MODEL_GENERATED_DRAFT     ; AI‑generated proposal marked as draft
  MODEL_SELF_CORRECTION     ; AI self‑audit, not billed as human labor
endenum

enum EvidenceMode
  TOPIC_VECTOR_ONLY      ; no verbatim text, embeddings + metadata only
  REDACTED_TEXT_SNIPPET  ; short snippet with redactions, corridor‑bounded
  FULL_TEXT_LOCAL_ONLY   ; full text, but must remain local‑first (no export)
endenum

enum ConsentScope
  SINGLE_TASK      ; only for this task/job
  PROJECT_BOUNDED  ; this project + replays
  ECOSYSTEM_POOL   ; anonymized, across EcoNet constellation
endenum

enum NeurorightsFlag
  NEURORIGHTS_SAFE       ; passes corridor and BCI/mental‑privacy checks
  REQUIRES_REVIEW        ; borderline, requires human governance review
  NEURORIGHTS_REJECTED   ; forbidden, must not be stored or monetized
endenum

fields
  event_id              hex64          mandatory true  unique true
  worker_did            utf8id64       mandatory true  description "Augmented citizen or worker DID fragment"
  labor_source_kind     LaborSourceKind mandatory true
  evidence_mode         EvidenceMode   mandatory true
  consent_scope         ConsentScope   mandatory true
  corridor_id           utf8id64       mandatory true  description "Link to NeurorightCorridorSpec corridor_id"
  neurorights_flag      NeurorightsFlag mandatory true
  stake_pledged_eco     float64        mandatory true  min 0.0  description "Eco‑token stake locked with event"
  stake_pledged_fiat    float64        mandatory true  min 0.0  description "Fiat‑equivalent stake, local currency"
  labor_seconds         float64        mandatory true  min 0.0  max 86400.0
  topic_vector_sha256   hex64          mandatory true  description "Hash of topic vector payload (stored out‑of‑band)"
  topic_dim             int32          mandatory true  min 8     max 4096
  consent_timestamp_ms  int64          mandatory true
  region_code           utf8id16       mandatory true  description "e.g., US-AZ-PHX"
  project_id            utf8id64       mandatory true
  evidencehex           hex64          mandatory true  description "ProvenanceKernel2026v1 canonical hash"
  signinghex            hex64          mandatory false
  created_utc           datetime       mandatory true
  updated_utc           datetime       mandatory true
endfields

invariants
  requirefield event_id
  requirefield worker_did
  requirefield labor_source_kind
  requirefield neurorights_flag
  requirefield topic_vector_sha256

  forbiddropcolumn worker_did
  forbiddropcolumn labor_source_kind
  forbiddropcolumn neurorights_flag
  forbiddropcolumn topic_vector_sha256

  safestep_labor
    vtceiling   0.13
    corridorpresent labor_source_kind, neurorights_flag, stake_pledged_eco, stake_pledged_fiat
  endsafestep_labor
endinvariants
