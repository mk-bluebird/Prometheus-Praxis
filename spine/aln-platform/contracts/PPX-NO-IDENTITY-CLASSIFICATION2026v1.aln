TITLE PPX-NO-IDENTITY-CLASSIFICATION2026v1
FAMILY PPX-NO-IDENTITY-CLASSIFICATION
VERSION 1.0.0
CATEGORY CONTRACT
SUMMARY Prohibits any identity, trait, or protected-class inference on PPX-bound workloads.

meta
  ownerrepo      string  eco_restoration_shard
  ownerroleband  string  GOV
  signingdid     string  bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
  spechashhex    hex64   0x8f7e6d5c4b3a2910
endmeta

forbidden_symbols
  "race"
  "ethnicity"
  "gender"
  "sexual_orientation"
  "religion"
  "political_affiliation"
  "health_status"
  "genetic_data"
  "biometric_identity"
  "face_embedding"
  "voiceprint"
endforbidden_symbols

source_sink_policy
  sources
    CHAT_LOG_TOPIC_VECTORS
    HEALTH_DATASETS_DEIDENTIFIED
    SENSOR_STREAMS_ENVIRONMENTAL
  endsources

  sinks
    MODEL_WEIGHTS_NONIDENTITY
    DASHBOARD_AGGREGATES
    GOVERNANCE_METERING
  endsinks

  forbid_sink
    RAW_CHAT_TEXT
    FACE_EMBEDDING_STORE
    IDENTITY_CLASSIFIER_OUTPUT
  endforbid_sink
endsource_sink_policy

invariants
  -- Any workload bound to this contract must not contain forbidden symbols in schema or runtime keys.
  forbid symbol_usage forbidden_symbols

  -- No edge may exist from protected sources to forbidden sinks.
  forbid flow CHAT_LOG_TOPIC_VECTORS -> IDENTITY_CLASSIFIER_OUTPUT
  forbid flow HEALTH_DATASETS_DEIDENTIFIED -> IDENTITY_CLASSIFIER_OUTPUT

  -- Contract must be verified before lane PROD placement.
  require contract_verified PPX-NO-IDENTITY-CLASSIFICATION before_lane PROD
endinvariants
