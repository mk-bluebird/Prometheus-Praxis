SHARD workload_energyreq_dvt_20260713 {
  META {
    did_owner      = "bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7";
    aln_version    = "2.0";
    phoenix_hex    = "0x20260713PHX3345NWorkloadEnergyDeltaVtShard";
