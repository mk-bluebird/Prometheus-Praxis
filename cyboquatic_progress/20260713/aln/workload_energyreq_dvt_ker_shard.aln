    corridor_note  = "Energy tailwind, hydraulics safe, uncertainty moderate; non-actuating diagnostic workload shard.";
  }

  KER {
    # Knowledge factor: high when residual does not increase and energy risk is low.
    kfactor = 0.91;

    # Eco-impact factor: high when vt is small and Vt does not increase, preserving Lyapunov-safe tailwind.
    efactor = 0.88;

    # Risk-of-harm: explicit residual risk from hydraulics and uncertainty; kept below 0.20.
    rfactor = 0.17;
  }

  WORKLOAD {
    energy_req_j      = 6.0;
    energy_surplus_j  = 8.4;
    hydraulic_risk    = 0.15;
    uncertainty_risk  = 0.35;
    renergy           = 0.0;
    rhydraulic        = 0.15;
    runcertainty      = 0.35;
    vt_before         = 0.18;
    vt_after          = 0.80;
    delta_vt          = 0.62;
  }

  EVIDENCE {
    db_path       = "db/cyboquatic_daily_progress.sqlite";
    table_name    = "daily_progress";
    node_id       = "PHX-CANAL-NODE-WL-02";
    sample_id     = "PHX-WL-SAMPLE-0002";
    timestamp_utc = "2026-07-13T233500Z";
  }

  NEXT_STEPS {
    research_query_1 = "Calibrate ENERGY_TAILWIND_SAFE_RATIO using Phoenix grid carbon-intensity and node surplus traces to harden renergy.";
    research_query_2 = "Extend workload residual to include canal-velocity (rvelocity) and sensor health (rcalib, rsigma) planes for PFAS fate corridors.";
    research_query_3 = "Replay historical cyboquatic workloads to validate K,E,R gating rules (K>=0.9,E>=0.9,R<=0.15) before production coupling.";
  }
}
