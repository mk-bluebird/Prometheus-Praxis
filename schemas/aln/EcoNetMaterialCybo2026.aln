spec: EcoNetMaterialCybo2026
  version: 1.0.0
  
  shard_schema:
    path: "qpudatashards/particles/EcoNetMaterialCyboT90PFAS2026v1.csv"
    role: MaterialNode
    fields:
      - node_id
      - material_id
      - matrix_id
      - temp_c
      - pH
      - t90_days
      - r_tox
      - r_micro
      - r_leach_cec
      - r_pfas_resid
      - R_residual
      - K_score
      - E_score
      - criterion_pass
      - eco_impact_level
      - hex_stamp
      - notes
  
  corridors:
    t90_max_days: 180.0
    r_tox_gold_max: 0.10
    r_micro_max: 0.05
    r_leach_cec_max: 0.10
    r_pfas_resid_max: 0.10
    R_max: 0.13
    K_min: 0.90
    E_min: 0.90
  
  kernels:
    risk_coordinates:
      - r_t90: "from t90 vs. corridor"
      - r_tox
      - r_micro
      - r_leach_cec
      - r_pfas_resid
    
    ERLK_weights:
      w_t90: 1.0
      w_tox: 1.2
      w_micro: 1.0
      w_leach: 1.1
      w_pfas: 1.5
    
    definition:
      R_residual: "sum_j(w_j * r_j)"
    
    constraint:
      "R_residual <= R_max"
    
    lyapunov:
      "V(t+1) - V(t) <= 0"
  
  KER:
    K_definition: "fraction of risk coordinates with corridor-backed data"
    E_definition: "normalized eco-benefit from CEIM mass-load kernels"
    R_definition: "R_residual from ERLK"
    thresholds:
      K: ">= K_min"
      E: ">= E_min"
      R: "<= R_max"
  
  admissibility_gates:
    gate_1_kinetics:
      condition: "t90_days <= t90_max_days"
    gate_2_toxicity:
      condition: "r_tox <= r_tox_gold_max"
    gate_3_micro:
      condition: "r_micro <= r_micro_max"
    gate_4_leach_cec:
      condition: "r_leach_cec <= r_leach_cec_max"
    gate_5_pfas:
      condition: "r_pfas_resid <= r_pfas_resid_max"
    gate_6_KER:
      condition: "K_score >= K_min AND E_score >= E_min AND R_residual <= R_max"
  
  write_policy:
    "Only post-gate, governance-grade rows are written"
    shard_writer: "EcoNetMaterialCyboKernels.cxx"
    condition: "all admissibility_gates satisfied"
