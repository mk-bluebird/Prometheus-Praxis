schema ecosafety.unsabotageableconstitution2026v1

meta
  title "EcoSafety Unsabotageable Constitution 2026 v1"
  region "Phoenix-AZ"
  jurisdiction "Maricopa-County-US"
  description """
  Constitutional shard for ecosafety governance under Eibon superchair rules.

  It binds:
  - Hardened invariant enforcement kernels
    * Non-Compensation Kernel
    * Data Quality Kernel
    * Topology & Underspecification Kernel

  - Cryptographic provenance requirements
    * ProvenanceKernel2026v1
    * VirtaupgradeLedger

  - Governance surfaces
    * econetrepoindex / econetlayer (manifests)
    * lanestatusshard / kerdeployable (lane gates)

  This shard is FROZEN and must only be superseded by a higher
  semver version via a ProvenanceKernel2026v1 + VirtaupgradeLedger
  upgrade path with monotone KER proofs.
  """
  status "FROZEN"
end

import ecosafety.core.v2.RiskVector
import ecosafety.core.v2.LyapunovWeights
import ecosafety.core.v2.KerWindow
import ecosafety.core.v2.KerDeployableConfig
import ecosafety.core.v2.DeployDecision
import ecosafety.kernels.noncompensation.v1.NonCompensationVerdict
import ecosafety.kernels.dataquality.v1.DataQualityVerdict
import ecosafety.kernels.topology.v1.TopologyVerdict

import ecosafety.provenance.ProvenanceKernel2026v1
import ecosafety.provenance.VirtaupgradeLedger2026v1

import econet.discovery.EcoNetRepoIndex2026v1
import econet.discovery.LaneStatusShard2026v1
import econet.discovery.DefinitionRegistry2026v1
import econet.discovery.CorridorDefinition2026v1

record NonCompensationKernelConfig
  field nonoffsettableplanes string[]
  field goldband map<string, f32>
  field epsilon f32
end

record DataQualityKernelConfig
  field rcalibgold f32
  field rcalibhard f32
  field rsigmagold f32
  field rsigmahard f32
  field dtweight f32
end

record TopologyKernelConfig
  field wtopology f32
  field wunderspec f32
  field rtopologyhard f32
  field runderspechard f32
end

record ConstitutionKernelConfig
  field noncomp NonCompensationKernelConfig
  field dataq DataQualityKernelConfig
  field topo TopologyKernelConfig
end

record ConstitutionVerdict
  field noncomp NonCompensationVerdict
  field dataq DataQualityVerdict
  field topo TopologyVerdict
  field vt_prev f32
  field vt_next f32
  field k_prev f32
  field k_next f32
  field e_prev f32
  field e_next f32
  field r_prev f32
  field r_next f32
  field admissible bool
  field reason string
end

record ConstitutionUpgradeEvidence
  field upgrade_id string
  field spechash_old string
  field spechash_new string
  field vt_old f32
  field vt_new f32
  field k_old f32
  field k_new f32
  field e_old f32
  field e_new f32
  field r_old f32
  field r_new f32
  field monotone_ok bool
  field evidencehex string
  field parentevidencehex string
  field signingdid string
end

predicate invariant.noncompensation
  """
  For all windows where any non-offsettable plane p in N has
  r_p,t >= gold_p and r_p,t+1 > r_p,t:

    R_{t+1} >= R_t
    E_{t+1} <= E_{t}
    K_{t+1} <= K_{t}

  This ensures that degradation in carbon / biodiversity (or other
  non-offsettable planes) cannot be compensated by improvements in
  other planes. It is evaluated over KerWindow snapshots and
  NonCompensationKernelVerdict.
  """
  expr
    forall w in KerWindow,
           v in NonCompensationVerdict
      where v.window_id == w.id
      and   v.triggered == true
      implies
        v.r_next >= v.r_prev
        and v.e_next <= v.e_prev
        and v.k_next <= v.k_prev
end

predicate invariant.dataquality
  """
  Data quality kernel constraints:

  If rcalib or rsigma increase between windows, then
    K_adj,next <= K_adj,prev
    E_adj,next <= E_adj,prev
    R_next     >= R_prev

  where K_adj = K * D_combined, E_adj = E * D_combined and
  D_combined is a trust discount derived from rcalib, rsigma.

  This ensures that higher uncertainty never inflates K/E or hides R.
  """
  expr
    forall w_prev in KerWindow,
           w_next in KerWindow,
           dq in DataQualityVerdict
      where dq.window_prev_id == w_prev.id
      and   dq.window_next_id == w_next.id
      and  (dq.rcalib_next > dq.rcalib_prev
            or dq.rsigma_next > dq.rsigma_prev)
      implies
        dq.k_adj_next <= dq.k_adj_prev
        and dq.e_adj_next <= dq.e_adj_prev
        and dq.r_next >= dq.r_prev
end

predicate invariant.topology
  """
  Topology & underspecification kernel constraints:

  Extended residual:
    V'_t = V_t
           + w_topology * r_topology,t^2
           + w_underspec * r_underspec,t^2

  with w_topology, w_underspec >= 0 and hard bands
  on r_topology, r_underspec per TopologyKernelConfig.

  Any governance gap increases residual risk and can
  independently block deployment.
  """
  expr
    forall tv in TopologyVerdict
      implies
        tv.v_ext >= tv.v_base
        and tv.r_topology <= tv.r_topology_hard
        and tv.r_underspec <= tv.r_underspec_hard
end

predicate invariant.kerdeployable_with_constitution
  """
  kerdeployable gate under the constitution:

  - Standard KER gates:
      K >= 0.90, E >= 0.90, R <= 0.13

  - Non-compensation holds (invariant.noncompensation)

  - Data quality holds (invariant.dataquality)

  - Topology & underspecification holds (invariant.topology)

  Any failure yields DeployDecision != Deploy for PROD lanes.
  """
  expr
    forall lane in LaneStatusShard2026v1,
           win in KerWindow,
           cfg in KerDeployableConfig,
           dec in DeployDecision
      where lane.lane == "PROD"
      and   lane.kernel_id == win.kernel_id
      and   cfg.profile == "PROD"
      and   dec.kernel_id == win.kernel_id
      implies
        (dec == "Deploy") <=>
          (win.knowledge_factor >= cfg.kmin
           and win.eco_impact >= cfg.emin
           and win.risk_of_harm <= cfg.rmax
           and invariant.noncompensation()
           and invariant.dataquality()
           and invariant.topology())
end

predicate invariant.provenance_required
  """
  Every constitution-relevant artifact must have:

  - ProvenanceKernel2026v1-compliant evidencehex
  - parentevidencehex forming a valid hash chain
  - signingdid bound to a known Eibon superchair DID

  Artifacts include:
    - ecosafety.unsabotageableconstitution2026v1
    - ecosafety kernels (noncomp, dataquality, topology)
    - kerdeployable configs
    - econetrepoindex / econetlayer entries
    - LaneStatusShard definitions
  """
  expr
    forall art in ProvenanceKernel2026v1.Artifact
      where art.role in [
        "ecosafety.constitution",
        "ecosafety.kernel.noncompensation",
        "ecosafety.kernel.dataquality",
        "ecosafety.kernel.topology",
        "ecosafety.kerdeployable",
        "econet.repoindex",
        "econet.repo.layer",
        "econet.lanestatus"
      ]
      implies
        art.evidencehex != ""
        and art.signingdid != ""
        and art.chain_valid == true
end

predicate invariant.virtaupgrade_monotone
  """
  VirtaupgradeLedger monotonicity requirement:

  For any upgrade affecting ecosafety constitution,
  kernels, corridors, or manifests:

    V_new <= V_old
    R_new <= R_old
    E_new >= E_old

  and monotone_ok == true.

  This is evaluated per ConstitutionUpgradeEvidence row.
  """
  expr
    forall u in VirtaupgradeLedger2026v1,
           ce in ConstitutionUpgradeEvidence
      where u.upgrade_id == ce.upgrade_id
      implies
        ce.vt_new <= ce.vt_old
        and ce.r_new <= ce.r_old
        and ce.e_new >= ce.e_old
        and ce.monotone_ok == true
end

predicate invariant.manifest_binding
  """
  econetrepoindex and econetlayer must:

  - Be present for any repo contributing ecosafety or
    ecosafety-dependent tools (roleband in ["ECOSAFETY", "GOVERNANCE"]).

  - Be signed by an approved DID (Eibon superchair rollup).

  - Pass econetrepomanifestlint, ensuring:
      * nonactuatingonly=1 for analysis repos
      * no actuator library dependencies
      * lane and role bands consistent with DefinitionRegistry

  Violations raise r_topology and can block kerdeployable.
  """
  expr
    forall repo in EcoNetRepoIndex2026v1
      where repo.roleband in ["ECOSAFETY", "GOVERNANCE"]
      implies
        repo.manifest_present == true
        and repo.manifest_signed == true
        and repo.manifest_lint_ok == true
end

predicate invariant.lane_ker_thresholds
  """
  Lane thresholds under Eibon superchair:

  - PROD lanes:
      K >= 0.90, E >= 0.90, R <= 0.13

  - EXPPROD lanes:
      K >= 0.80, E >= 0.80, R <= 0.20

  - RESEARCH lanes:
      no hard K/E/R constraints, but all three
      invariant kernels must still run and log verdicts.

  LaneStatusShard must encode these thresholds and match
  kerdeployable decisions.
  """
  expr
    forall lane in LaneStatusShard2026v1
      implies
        if lane.lane == "PROD" then
          lane.kmin == 0.90
          and lane.emin == 0.90
          and lane.rmax == 0.13
        else if lane.lane == "EXPPROD" then
          lane.kmin == 0.80
          and lane.emin == 0.80
          and lane.rmax == 0.20
        else
          true
end

predicate invariant.corridor_definition_unique
  """
  For any regionid, nodefamily, corridorvarid triple:

    exactly one active CorridorDefinition row exists.

  This prevents ambiguous corridor bands and ensures
  controllers never arbitrate multiple active definitions.
  """
  expr
    forall regionid in CorridorDefinition2026v1.regionid,
           nodefamily in CorridorDefinition2026v1.nodefamily,
           corridorvarid in CorridorDefinition2026v1.corridorvarid
      implies
        count def in CorridorDefinition2026v1
          where def.regionid == regionid
          and   def.nodefamily == nodefamily
          and   def.corridorvarid == corridorvarid
          and   def.isactive == true
        == 1
end

predicate invariant.constitution_binding
  """
  Master invariant tying all others together.

  Any environment that declares ecosafety.unsabotageableconstitution2026v1
  as active MUST:

  - Enforce invariant.noncompensation
  - Enforce invariant.dataquality
  - Enforce invariant.topology
  - Enforce invariant.kerdeployable_with_constitution
  - Enforce invariant.provenance_required
  - Enforce invariant.virtaupgrade_monotone
  - Enforce invariant.manifest_binding
  - Enforce invariant.lane_ker_thresholds
  - Enforce invariant.corridor_definition_unique

  CI must fail any change set that violates one or more of these.
  """
  expr
    invariant.noncompensation()
    and invariant.dataquality()
    and invariant.topology()
    and invariant.kerdeployable_with_constitution()
    and invariant.provenance_required()
    and invariant.virtaupgrade_monotone()
    and invariant.manifest_binding()
    and invariant.lane_ker_thresholds()
    and invariant.corridor_definition_unique()
end
