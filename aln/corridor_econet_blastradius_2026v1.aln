particle EconetBlastRadiusSpine {
  did_owner      = "bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7";
  version        = "2026v1";
  lane           = "RESEARCH";
  non_actuating  = true;
  finance_forbidden = true;
}

contract CorridorEconetBlastRadiusSpine {
  require EconetBlastRadiusSpine.non_actuating == true;
  require EconetBlastRadiusSpine.finance_forbidden == true;

  predicate schema_only_descriptive(sql_file) {
    sql_file.table_names subset_of {
      "repo","shardinstance","blastradius_link","workload_ledger",
      "econet_repoindex","econet_layer"
    };
    sql_file.no_triggers == true;
    sql_file.no_update_delete_on_workload == true;
  }

  predicate lane_bounds(shard) {
    shard.ker_k >= 0.90;
    shard.ker_e >= 0.90;
    shard.ker_r <= 0.13;
  }

  rule no_compile_if_actuating(sql_file) {
    deny if not schema_only_descriptive(sql_file);
  }

  rule no_deploy_if_lane_weak(shard) {
    deny if not lane_bounds(shard);
  }
}
