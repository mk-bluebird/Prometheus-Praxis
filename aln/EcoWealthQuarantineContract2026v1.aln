enum QuarantineStatus2026v1
    ACTIVE
    RELEASED
endenum

enum QuarantineCause2026v1
    RISK_SPIKE
    DATA_QUALITY
    GOVERNANCE_ORDER
    SENSOR_CONFLICT
    ROH_VIOLATION
    OTHER
endenum

enum QuarantineScope2026v1
    STEWARD
    SHARD
    REGION
    CONTRACT
endenum

enum QuarantineSeverity2026v1
    SOFT
    HARD
endenum

record EcoWealthQuarantineRule2026v1
    contractid         uint64
    ruleid             uint64
    scope              QuarantineScope2026v1
    severity           QuarantineSeverity2026v1
    cause              QuarantineCause2026v1
    max_propagation_s  uint32
    apply_to_paycomp   bool
    apply_to_lane      bool
    auto_clear_s       uint32
    require_roh_anchor bool
    notes              string
endrecord

record EcoWealthQuarantineState2026v1
    scope                       QuarantineScope2026v1
    steward_id                  string optional
    shardid                     uint64 optional
    region                      string optional
    contractid                  uint64 optional
    active                      bool
    status                      QuarantineStatus2026v1
    severity                    QuarantineSeverity2026v1
    cause                       QuarantineCause2026v1
    ruleid                      uint64
    rresponsibility             float64 optional
    rresponsibility_threshold   float64 optional
    kerblock_id                 string
    ts_asserted_utc             datetime
    first_observed_in_paycomp   string optional
    first_observed_in_lane      string optional
    ts_cleared_utc              datetime optional
    cleared_by_did              string optional
    rohanchorhex                string optional
endrecord

record EcoWealthQuarantineContract2026v1Record
    quarantine_id               string
    stewarddid                  string
    region                      string
    lane                        string
    scope                       QuarantineScope2026v1
    severity                    QuarantineSeverity2026v1
    reason                      string
    rule_id                     string
    block_id                    string
    rresponsibility             float64
    rresponsibility_threshold   float64
    status                      QuarantineStatus2026v1
    valid_from_utc              string
    valid_until_utc             string
    kerblock_id                 string
    evidencehex                 string
    signingdid                  string
    created_utc                 string
endrecord

section invariants
  text
    INV-1: Bounded propagation delay within KerBlock+1.

    For any EcoWealthQuarantineState2026v1 with active=true and kerblock_id = B_k:

    - If apply_to_paycomp=true in the corresponding EcoWealthQuarantineRule2026v1,
      then first_observed_in_paycomp MUST be either B_k or B_{k+1}, and Paycomp
      MUST reject or hold all matching flows for all KerBlocks B_j with
      j >= index(B_k).

    - If apply_to_lane=true, then first_observed_in_lane MUST be either B_k or
      B_{k+1}, and lane promotion logic MUST reject all promotions whose evidence
      window intersects [ts_asserted_utc, ts_cleared_utc) for the quarantined scope.

    INV-2: No retroactive relaxation.

    Once active=true for a given scope and KerBlock B_k:

    - No Paycomp KerBlock B_j with j >= index(B_k) may process a payout that
      would have been blocked under the quarantine rule.
    - No lane promotion KerBlock B_j with j >= index(B_k) may accept a promotion
      that would have been rejected under the quarantine rule.

    This is enforced by requiring Paycomp and lane modules to re-evaluate
    quarantine state for all relevant scopes at the start of each KerBlock,
    and by requiring eco_wealth_ledger and LaneStatus shards to record the
    KerBlock id and quarantine state used for each decision.

    INV-3: RoH-coupled clearance.

    If require_roh_anchor=true on the originating EcoWealthQuarantineRule2026v1:

    - ts_cleared_utc MUST NOT be set unless rohanchorhex is present and valid
      under the RoH contract, and cleared_by_did has a governance role in the
      GOV band.

    Clearing quarantine does not retroactively change past Paycomp or lane
    decisions; it only allows future KerBlocks to proceed.
  end
endsection

