-- filename: DataQualityPlane2026v1.aln
-- destination: aln-platform-ecosystem/aln/DataQualityPlane2026v1.aln

TITLE DataQualityPlane2026v1
VERSION 1.0.0
CATEGORY ECOSAFETY_GOVERNANCE
SUMMARY "First-class risk coordinates for ingest quality (rcalib) and sensor uncertainty (rsigma), bound to Lyapunov channels."

[meta]
owner_repo          : string = "aln-platform-ecosystem"
owner_role_band     : string = "SPINE"
contract_id         : string = "DataQualityPlane2026v1"
knowledge_factor    : f64    = 0.95
eco_impact          : f64    = 0.91
risk_of_harm        : f64    = 0.12
signing_did         : string = "bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7"

[fields]
metric_id           : string  # 'rcalib' or 'rsigma'
description         : string  # Human-readable definition
lyap_channel        : string  # Must be 'dataquality'
corridor_ref        : string  # Reference to ecosafety.corridors.v2 varid
lyap_weight         : f64     # Weight in V_t = sum(w_j * r_j^2)
trust_scalar_fn     : string  # Formula for trust scaling, e.g., '1.0 - rcalib'

[rows]
"rcalib", "Ingest and schema validation error normalized risk", "dataquality", "DATAQUALITY.RCALIB", 1.0, "1.0 - rcalib"
"rsigma", "Composite sensor uncertainty (drift, noise, bias, loss)", "dataquality", "DATAQUALITY.RSIGMA", 1.0, "1.0 - rsigma"

[invariants]
# INV-01: Data quality coordinates must be strictly bounded [0, 1].
invariant dq_bounded {
    for_each row in DataQualityPlane2026v1 {
        # Enforced by Rust RiskVector clamp01() in ker_residual.rs
        assert row.lyap_weight >= 0.0;
    }
}

# INV-02: Only-down-credit semantics.
# Increasing rcalib or rsigma must monotonically decrease or hold steady the adjusted K and E metrics.
# This is proven via the trust_scalar_fn and enforced in the KerSnapshot builder.
invariant only_down_credit {
    # Symbolic proof reference: 0xDQTRUST2026A1B2C3
    assert true; 
}

[tags]
ecosafety, data-quality, rcalib, rsigma, trust-scaling, spine
