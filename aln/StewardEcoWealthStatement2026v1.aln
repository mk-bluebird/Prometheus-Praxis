aln StewardEcoWealthStatement2026v1
version 1.0.0
controllerid ECO-StewardEcoWealthStatement-2026v1
owneralnid bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
network ALN-MAINNET
issuedutc 2026-05-02T21:00:00Z
category QPUDATASHARD

record StewardEcoWealthStatement2026v1Record
    -- Steward identity and window
    statementid              string
    stewarddid               string
    region                   string        # e.g. Phoenix-AZ-US
    lane                     string        # RESEARCH, EXPPROD, PROD
    windowstartutc           string
    windowendutc             string

    -- Kernel and corridor context
    ecowealthkernelid        string        # e.g. EcoWealthKernel2026v1
    lane_policy_id           string        # e.g. EcoWealthLanePolicy2026v1
    corridor_contract_id     string        # corridor set applied
    planeweights_contract_id string        # planeweightsplane contract

    -- Aggregated KER metrics over the window
    k_avg                    float64
    e_avg                    float64
    r_avg                    float64
    vt_trend                 float64       # slope of residual over window
    rtopology_avg            float64
    rportfolio_diversity     float64
    rresponsibility          float64

    -- Education and representation modifiers
    mk_education             float64       # education multiplier
    delta_e_phys             float64       # physical ecoimpact delta
    representationweight     float64       # weight from regionrepresentation
    s_region                 float64       # CEIM-derived regional score

    -- Portfolio structure and diversity
    archetype_count          int64
    n_max_archetypes         int64
    archetype_mix_hash       string        # hash of archetype share vector

    -- Plane-specific aggregates (examples: carbon, biodiversity, energy)
    e_carbon                 float64
    r_carbon                 float64
    e_biodiversity           float64
    r_biodiversity           float64
    e_energy                 float64
    r_energy                 float64
    e_hydrology              float64
    r_hydrology              float64
    e_materials              float64
    r_materials              float64
    e_dataquality            float64
    r_dataquality            float64
    e_topology               float64
    r_topology_plane         float64

    -- Wealth and reward fields
    w_gross                  float64       # gross ecowealth before discounts
    w_trust_discounted       float64       # after trust and data discounts
    w_final                  float64       # final ecowealth credited
    trust_discount_data      float64
    trust_discount_region    float64
    b_s_topology_bonus       float64       # B_s bonus term from topology

    -- Governance and provenance
    migration_version        string        # DB migration tag
    constellationdb_hash     string
    shardset_hash            string
    lane_verdict_id          string        # reference to LaneStatus shard
    topology_audit_id        string        # reference to topology audit shard
    evidencehex              string
    signingdid               string
    createdutc               string
endrecord

section statement_examples
