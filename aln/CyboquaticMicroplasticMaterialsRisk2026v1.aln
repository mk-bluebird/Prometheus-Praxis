CONTRACTS
require corridor_present("microplastics");

invariant safestep_ecosafety:
vt_next <= vt_current;

invariant lifeforce_floor_guard:
lifeforce_next >= lifeforce_floor;

invariant rmat_bounded:
0.0 <= Rmat <= Rmat_max;

high_priority_plane microplastics non_offsettable;

rule violated_corridor_derate_stop:
if Rmat > Rmat_max then GovernanceDecision := "Stop";

rule lifeforce_penalty_update:
LIFEFORCE_next := max(LIFEFORCE_floor,
LIFEFORCE_prev - gamma * Rmat);

rule lyapunov_update:
vt_next := vt_current
+ w_mat * (Rmat^2 - Rmat_prev^2)
+ sum_other_planes_delta;
END CONTRACTS

GOVERNANCE
