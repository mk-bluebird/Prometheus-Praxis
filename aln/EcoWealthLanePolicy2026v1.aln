record EcoWealthLanePolicy2026v1Record
    laneid                  string   # RESEARCH, EXPPROD, PROD
    kmin_base               float64  # base minimum K for lane
    emin_base               float64  # base minimum E for lane
    rmax_base               float64  # base maximum R for lane
    f_E_coeff_a             float64  # tightening coefficient for E (per quarter)
    f_R_coeff_b             float64  # tightening coefficient for R (per quarter)
    max_delta_emin_per_q    float64  # maximum allowed increase in emin per quarter
    max_delta_rmax_per_q    float64  # maximum allowed decrease in rmax per quarter
    vt_trend_floor          float64  # minimum nonpositive residual trend (e.g. 0.0)
    window_len_days         int64    # evidence window length in days
    min_windows             int64    # minimum number of windows before promotion
    evidencehex             string   # hexstamp of policy evidence
    signingdid              string   # DID of lane governor
endrecord

