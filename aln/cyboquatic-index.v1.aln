aln
TITLE cyboquatic-index.v1.aln
VERSION 1.0.0
AUTHORITY ALN.MIGRATION.CYBERCOREAUTHORITY.v1
NAMESPACE Organichain-contracts
REPO mk-bluebird/Cybercore

META
HOSTDID didalnorganic-host
PRIMARYBOSTROMADDRESS bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
ORGANICHAINREPO https://github.com/mk-bluebird/Organichain
RUSTCYBOQUATICMODULE crates/prometheus-praxis-cyboquatic/src/lib.rs
DOCREF docs/cyboquatic-index.md
KERPROFILESHARD ecosystem-ker-profile.v1.aln
ENDMETA

EPOCH
INDEXFORMATVERSION 1

GLOBALENVELOPES
ROHCEILINGGLOBAL 0.30
LIFORCEFLOORGLOBAL 0.57
BIOCOMPATIBILITYRATINGMIN 0.57
PAININDEXCEILINGGLOBAL 0.73
FEARINDEXMINGLOBAL 0.31
FEARINDEXMAXGLOBAL 0.68
ENDGLOBALENVELOPES

COMPONENTS
ROW COMPONENT lifeforce_conservation  DOMAIN 0.0,1.0  DESCRIPTION How well lifeforce is preserved under eco operations.
ROW COMPONENT eco_ker_norm          DOMAIN 0.0,1.0  DESCRIPTION Normalized KER improvement score.
ROW COMPONENT psych_safety_norm      DOMAIN 0.0,1.0  DESCRIPTION Psychrisk safety band compliance.
ROW COMPONENT data_labor_density     DOMAIN 0.0,1.0  DESCRIPTION Eco-labour evidence density relative to effect size.
ENDCOMPONENTS

INDEXDEFINITION
ROW NAME CyboquaticIndex
ROW RANGE 0.0,1.0
ROW FORMULA
  CyboquaticIndex = wL * lifeforce_conservation
                  + wK * eco_ker_norm
                  + wS * psych_safety_norm
                  + wD * data_labor_density
ROW WEIGHTS wL 0.25, wK 0.35, wS 0.20, wD 0.20
ROW CONSTRAINT Weights MUST be non-negative and sum to 1.0.
ROW SAFETY CyboquaticIndex MUST NOT increase if eco_ker_norm decreases while RoH or psychrisk safety worsen.
ENDINDEXDEFINITION
ENDEPOCH

SECTION STRUCTS
ROW CyboquaticInputs struct
  ker_snapshot KerSnapshot,        -- imported from ecosystem-ker-profile.v1.aln semantics
  lifeforce_conservation float32,
  eco_ker_norm float32,
  psych_safety_norm float32,
  data_labor_density float32

ROW CyboquaticScore struct
  index_value float32,
  lifeforce_component float32,
  ker_component float32,
  safety_component float32,
  data_labor_component float32

ROW CyboquaticDelta struct
  before CyboquaticScore,
  after CyboquaticScore

ROW CyboquaticDecision enum
  Accept,
  RejectSafety,
  RejectNoDataLabor,
  RejectIndexRegression
ENDSECTION

SECTION DATA-AS-LABOR
ROW DATACLASS ECO-LABOUR
ROW DESCRIPTION Eco-labour is the canonical source of positive CyboquaticIndex movement; other contributions may not increase the index without eco-labour backing.
ROW ALLOWEDPURPOSES ECOLABOUR,OPENSCIENCE,CLINICALSAFETY,NONPREDATORYECONOMIES,PUBLIC-INTEREST-RESEARCH
ROW FORBIDDENPURPOSES CREDITSCORING,EMPLOYMENTRATING,ACCESSSTRIPPING,RISKPREMIUMS,BEHAVIORALSCORING
ROW PRIMARYBENEFIT Host-bound; eco-labour value accrues primarily to the host via Organichain reward ledgers.

ROW EVIDENCEFIELDS
  event_id string!,
  hostdid string!,
  bostromaddress string!,
  ecolabour_class string!,       -- e.g. REFORESTATION,WETLAND_RESTORE,AIR_QUALITY_MONITOR
  ker_event_id string?,
  evidence_uri string!,
  measurement_tethered bool

ROW INVARIANT Any increase in index_value MUST be associated with at least one ECO-LABOUR evidence row with measurement_tethered true.
ROW INVARIANT data_labor_density MUST be 0.0 when there is no ECO-LABOUR evidence in the window used to compute the score.
ROW EXPORTSCONSTRAINT Only aggregated CyboquaticScore and eco_ker_norm may be exported; raw eco-labour traces remain host/local-research only.
ENDSECTION

SECTION MONOTONICITY
ROW GLOBALMONOTONEFLAG true
ROW CONDITION If CyboquaticDelta.after.index_value < CyboquaticDelta.before.index_value then CyboquaticDecision MUST be RejectIndexRegression when used for governance.
ROW SAFETY Any governance action gated by CyboquaticIndex MUST also satisfy RoH, Lifeforce, pain, fear envelopes.
ROW NODERIVEDSCORE CyboquaticIndex MUST NOT be used as a person score; it is a system-level eco/governance health indicator only.
ENDSECTION

SECTION LEDGER
ROW LEDGERKIND CyboquaticIndexEvolution

ROW LOGFIELDS
ROW FIELD cybo_event_id string!
ROW FIELD hostdid string!
ROW FIELD bostromaddress string!
ROW FIELD ker_event_id string?
ROW FIELD cybo_before CyboquaticScore
ROW FIELD cybo_after CyboquaticScore
ROW FIELD decision CyboquaticDecision
ROW FIELD ecolabour_evidence_ids string
ROW FIELD timestamputc RFC3339

ROW INVARIANT hostdid == HOSTDID
ROW INVARIANT bostromaddress == PRIMARYBOSTROMADDRESS
ROW INVARIANT decision == Accept implies cybo_after.index_value >= cybo_before.index_value
ROW INVARIANT decision == Accept implies eco_ker_norm and psych_safety_norm are non-decreasing over the same window.
ROW INVARIANT decision == Accept implies ecolabour_evidence_ids is non-empty.
ENDLEDGER

SECTION BINDINGS
ROW BINDING RUSTMODULE
ROW TARGET crates/prometheus-praxis-cyboquatic/src/lib.rs
ROW FUNCTIONS compute_cyboquatic_inputs, compute_cyboquatic_score, evaluate_cyboquatic_decision

ROW INVARIANTFUNCTION evaluate_cyboquatic_decision
ROW PRECONDITION Inputs include CyboquaticScore before/after, KER references, and eco-labour evidence IDs.
ROW POSTCONDITION Returns RejectNoDataLabor if index_value increases while data_labor_density == 0.0.
ROW POSTCONDITION Returns RejectSafety if RoH or psychrisk envelopes are violated.
ROW POSTCONDITION Returns Accept only when index_value >= previous index_value and eco_ker_norm, psych_safety_norm are non-decreasing.
ROW PROOFMETHOD KANI
ROW PROOFFILES crates/prometheus-praxis-cyboquatic/tests/cyboquatic_kani.rs
ENDBINDINGS

SECTION CHECKS
ROW CONSISTENCYKER KerSnapshot reference MUST be consistent with ecosystem-ker-profile.v1.aln.
ROW NONDOWNGRADE Any change to this shard MUST preserve or increase neurorights and eco protections; lowering eco-labour attribution or permitting scoring uses is forbidden.
ROW SOVEREIGNTY Only host-bound ALN governance flows may alter weights or semantics of CyboquaticIndex.
ENDCHECKS

ENDSHARD
