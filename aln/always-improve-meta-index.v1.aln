aln
TITLE always-improve-meta-index.v1.aln
VERSION 1.0.0
AUTHORITY ALN.MIGRATION.CYBERCOREAUTHORITY.v1
NAMESPACE Prometheus-Praxis
REPO mk-bluebird/Prometheus-Praxis

META
HOSTDID didalnorganic-host
PRIMARYBOSTROMADDRESS bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
DOCREF docs/always-improve-meta-index.md
ENDMETA

EPOCH
METAINDEXVERSION 1
WINDOW_RELEASES 5
ENDEPOCH

SECTION COMPONENTS
ROW COMPONENT lyapunov_stability_improvement
  DESCRIPTION Relative reduction in frequency/magnitude of Lyapunov residual spikes over the window.
  RANGE -1.0,1.0

ROW COMPONENT ker_fairness_improvement
  DESCRIPTION Change in median KER fairness ratio (closer to 1.0 is better).
  RANGE -1.0,1.0

ROW COMPONENT violation_latency_improvement
  DESCRIPTION Reduction in median time to remediate policy violations.
  RANGE -1.0,1.0
ENDSECTION

SECTION FORMULA
ROW NAME AlwaysImproveScore
ROW RANGE -1.0,1.0
ROW WEIGHTS wL 0.4, wK 0.3, wV 0.3
ROW DEFINITION
  AlwaysImproveScore =
    wL * lyapunov_stability_improvement +
    wK * ker_fairness_improvement +
    wV * violation_latency_improvement
ENDSECTION

SECTION PASS-CRITERIA
ROW CRITERION NonDecreasingMeta
  DESCRIPTION AlwaysImproveScore must be non-decreasing across consecutive release windows.
  CONDITION score_t >= score_t_minus_1

ROW CRITERION MinimumTrend
  DESCRIPTION Over any WINDOW_RELEASES, mean AlwaysImproveScore must be >= 0.0.
ENDSECTION

SECTION LEDGER
ROW LEDGERKIND AlwaysImproveWindow

ROW FIELD window_id string!
ROW FIELD releases_included string[]
ROW FIELD lyapunov_stability_improvement float32
ROW FIELD ker_fairness_improvement float32
ROW FIELD violation_latency_improvement float32
ROW FIELD always_improve_score float32
ROW FIELD timestamputc RFC3339
ENDLEDGER

SECTION CHECKS
ROW INVARIANT For production deployment, last window always_improve_score >= 0.0.
ROW INVARIANT For any two consecutive windows, score_current >= score_previous.
ENDCHECKS

ENDSHARD
