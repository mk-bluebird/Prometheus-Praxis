# DECISION SURFACE: ALLOW / DERATE / STOP

SECTION,DECISION_SURFACE

# Raw inputs re-exposed as view fields so engines can compute decisions identically in Rust and ALN

ROW,view,scalar,Vt,vt_residual,float,range-1,1,Lyapunov residual Vt
ROW,view,scalar,DN2N3,corridor_depth,float,range0,1,Sleep or depth-based corridor index DN2N3
ROW,view,scalar,Ucomb,corridor_uncertainty,float,range0,1,Combined uncertainty Ucomb
ROW,view,scalar,Lratio,load_budget_ratio,float,range0,1,Nightly load ratio LsleepLmax
ROW,view,scalar,BioCompat,biocompatibility_rating,float,range0,1,Biocompatibility rating
ROW,view,scalar,Pain,pain_index,float,range0,1,Pain index
ROW,view,scalar,Fear,fear_index,float,range0,1,Fear index
ROW,view,scalar,RoH,roh_ceiling,float,range0,1,Current Rate-of-Harm metric
ROW,view,scalar,LF,LIFEFORCE_level,float,range0,1,LIFEFORCE envelope level
ROW,view,scalar,Eco,ecosafety_index,float,range0,1,Ecosafety index
ROW,view,scalar,Blast,blast_radius_index,float,range0,1,Blast radius index
ROW,view,scalar,Trust,sensor_trust,float,range0,1,Sensor trust index

# Derived safety scalars

ROW,view,formula,CorridorOK, corridor_mask 1 AND DN2N3 0.35 AND Ucomb 0.35,string,readonly,Inside validated corridor with bounded uncertainty (scalar 0 or 1)[file:106]
ROW,view,formula,StabilityOK, absVt 0.35,string,readonly,Stability corridor for Vt residual
ROW,view,formula,LoadOK, Lratio 0.80,string,readonly,Load at or below 80 percent of nightly budget
ROW,view,formula,BioOK, BioCompat 0.57 AND Pain 0.73 AND Fear 0.68 AND Fear 0.31,string,readonly,Within default biophysical envelopes
ROW,view,formula,RoHLFOK, RoH 1.0 AND LF lifeforce_floor,string,readonly,RoH ceiling not exceeded and LIFEFORCE above floor
ROW,view,formula,EcoOK, Eco 0.70 AND Blast 0.40,string,readonly,Ecosafety and blast radius within moderated bounds
ROW,view,formula,TrustOK, Trust 0.70 AND sensor.trustFloorRespected true,string,readonly,Sensors and provenance above trust floor

# Banded decision outcomes

ROW,view,condition,ALLOW_BAND,
    CorridorOK 1
    AND StabilityOK true
    AND LoadOK true
    AND BioOK true
    AND RoHLFOK true
    AND EcoOK true
    AND TrustOK true,
    expression,
    All invariants in green zone; governance may proceed at full intensity

ROW,view,condition,DERATE_BAND,
    (CorridorOK 0 OR StabilityOK false OR LoadOK false OR EcoOK false OR TrustOK false)
    AND BioCompat 0.50
    AND Pain 0.80
    AND Fear 0.80
    AND LF lifeforce_floor 0.10,
    expression,
    Some invariants drifting but biophysical floors not yet crossed; governance must derate intensity and bandwidth

ROW,view,condition,STOP_BAND,
    BioCompat 0.50
    OR Pain 0.80
    OR Fear 0.80
    OR LF lifeforce_floor 0.10
    OR RoH 1.0
    OR Eco 0.50
    OR Blast 0.70
    OR Trust 0.50
    OR corridor_mask 0,
    expression,
    Hard violation of envelopes; governance must stop, enter safe-shell, and emit SafetyEpoch event

# RUST BINDINGS FOR BANDS

ROW,govmap,scalar,fn_allow_binding,prometheus_praxis_gate::decide_allow,string,immutable,Rust function implementing ALLOW_BAND logic
ROW,govmap,scalar,fn_derate_binding,prometheus_praxis_gate::decide_derate,string,immutable,Rust function implementing DERATE_BAND logic
ROW,govmap,scalar,fn_stop_binding,prometheus_praxis_gate::decide_stop,string,immutable,Rust function implementing STOP_BAND logic
ROW,govmap,scalar,fn_invariants_binding,prometheus_praxis_gate::verify_invariants,string,immutable,Rust function that proves band predicates match Kani-verified invariants

# NEURORIGHTS GATE (HARD FAIL-CLOSED)

SECTION,NEURORIGHTS_GATE
ROW,nrgate,formula,NeurorightsVectorOk,
    rights.mentalPrivacy
    rights.cognitiveLiberty
    rights.mentalIntegrity
    rights.noPunitiveXR
    rights.nonCommercialNeuralData
    rights.soulNonAddressable
    rights.noPersonScoring,
    string,readonly,
    Hard neurorights vector; all bits must be true

ROW,nrgate,condition,DenyWhenRightsFail,
    NeurorightsVectorOk false,
    expression,
    Any neurorights bit false forces STOP_BAND regardless of other envelopes

