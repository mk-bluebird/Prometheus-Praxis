aln EcoRepoIndex2026v1
version 1.0.0
controllerid ECO-Repo-Index-2026v1
owneralnid bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
network ALN-MAINNET
issuedutc 2026-05-02T21:00:00Z
category GOVERNANCE

record EcoRepoIndexEntry2026v1
    indexid        string   # stable id for this index shard
    reponame       string   # GitHub slug, e.g. eco_restoration_shard
    roleband       string   # SPINE, RESEARCH, ENGINE, MATERIAL, GOV, APP
    entries        string   # CSV of ALN spec ids with versions
    sql_migrations string   # CSV of db filenames applied
    rust_crates    string   # CSV of crate names in this repo
    evidencehex    string
    signingdid     string
    created_utc    string
endrecord

section example
    EcoRepoIndexEntry2026v1
        indexid        eco_restoration_shard-2026v1
        reponame       eco_restoration_shard
        roleband       SPINE
        entries        PlaneWeightsShard2026v1,StewardEcoWealthStatement2026v1,EcoWealthQuarantineContract2026v1
        sql_migrations db_basetables.sql,ecoplot_portfolio_diversity.sql,econetrepoindex.sql
        rust_crates    kerresidual,ecowealth
        evidencehex    eco-repo-index-2026v1
        signingdid     bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
        created_utc    2026-05-02T21:00:00Z
    end
endsection

