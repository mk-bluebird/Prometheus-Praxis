aln particle eco.beecorridor.envelope.v1

# Identity and linkage
field corridor_id text
field region_id text              # GlobeCellId or city shard identifier
field species_agent_id text       # links into Synthexis SpeciesAgent
field evidence_bundle_hex hex     # BeeCorridorEvidenceBundle key
field version u32

# Habitat continuity
field floral_area_connected_m2 f32
field nesting_site_density_per_ha f32
field pesticide_free_buffer_radius_m f32

# Bee activity indices
field flight_density_per_min_m2 f32
field foraging_success_rate f32          # 0..1
field shannon_diversity_index f32        # H' biodiversity index

# Exposure ceilings
field emf_intensity_hive_height_vpm f32  # corridor ceiling for EMF at hive height
field noise_level_db_a f32               # A-weighted noise ceiling
field light_spill_lux f32                # ALAN spill ceiling
field temperature_min_c f32
field temperature_max_c f32

# Governance metadata
field roh_ceiling f32                    # risk-of-harm ceiling for bee plane
field ker_required bool
field lane text                          # "RESEARCH" | "PILOT" | "PROD"

# -------------------------
# Envelope-evidence linkage
# -------------------------

# Every envelope must be backed by a non-empty evidence bundle.
rule evidence_linked
  when e eco.beecorridor.envelope.v1
  then require e.evidence_bundle_hex !

# Envelope ceilings must not exceed evidence-safe maxima.
rule envelope_respects_evidence
  when e eco.beecorridor.envelope.v1,
       b eco.beecorridor.evidencebundle.v1
  then require e.evidence_bundle_hex == b.bundle_hex
  require e.emf_intensity_hive_height_vpm <= b.emf_safe_max_vpm
  require e.noise_level_db_a              <= b.noise_safe_max_db_a
  require e.light_spill_lux               <= b.light_safe_max_lux
  require e.temperature_min_c             >= b.temp_min_c
  require e.temperature_max_c             <= b.temp_max_c

# Habitat continuity must meet minimum thresholds from evidence.
rule envelope_meets_habitat_minima
  when e eco.beecorridor.envelope.v1,
       b eco.beecorridor.evidencebundle.v1
  then require e.evidence_bundle_hex == b.bundle_hex
  require e.floral_area_connected_m2      >= b.floral_connected_min_m2
  require e.nesting_site_density_per_ha   >= b.nesting_min_density_per_ha

# No corridor widening when updating an envelope: changes may only tighten or
# preserve safety, never loosen it.
rule no_widening_when_upgrading
  when old eco.beecorridor.envelope.v1,
       new eco.beecorridor.envelope.v1
  then require old.corridor_id == new.corridor_id
  require new.version > old.version

  # Habitat non-regression
  forbid condition new.floral_area_connected_m2    < old.floral_area_connected_m2
  forbid condition new.nesting_site_density_per_ha < old.nesting_site_density_per_ha
  forbid condition new.pesticide_free_buffer_radius_m < old.pesticide_free_buffer_radius_m

  # Exposure non-widening (no higher ceilings)
  forbid condition new.emf_intensity_hive_height_vpm > old.emf_intensity_hive_height_vpm
  forbid condition new.noise_level_db_a              > old.noise_level_db_a
  forbid condition new.light_spill_lux               > old.light_spill_lux
  forbid condition new.temperature_min_c             < old.temperature_min_c
  forbid condition new.temperature_max_c             > old.temperature_max_c
