aln SovereignAIOriginVeto2026v2.aln
network ALN-MAINNET
shardid 0xsovereignveto2026abcd000000000000000000000000000002
owner.bostrom bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
timestamp.utc 2026-07-16T21:52:00Z

title SovereignAIOriginVeto2026v2
version 2

comment
  Strengthens ai_nonvoting predicate to require a human-signed override_hex
  for any HARD governance class. AI-origin proposals without override_hex
  are vetoed pre-deployment.
endcomment

particle GovernanceProposal2026v2
  field proposalid string required true
  field origin string required true      ; "HUMAN", "AI", "HYBRID"
  field governance_class string required true ; "SOFT", "MEDIUM", "HARD"
  field override_hex string required false ; hex-encoded human override signature
  field evidencehex string required true
endparticle

function ai_nonvoting_strict
  input GovernanceProposal2026v2
  output GovernanceProposal2026v2
endfunction

invariant ai_nonvoting_requires_override_for_hard
  forall p in GovernanceProposal2026v2
    if p.origin == "AI" and p.governance_class == "HARD"
      assert p.override_hex != ""
    endif
  endforall
endinvariant

invariant ai_nonvoting_forbids_unbacked_ai
  forall p in GovernanceProposal2026v2
    if p.origin == "AI" and p.governance_class == "HARD"
      assert p.override_hex != ""
      assert len(p.override_hex) >= 64
    endif
  endforall
endinvariant

block rust_enums
  language RUST
  module sovereign_ai_origin_veto
  content
    /// Auto-generated Rust enums for GovernanceProposal2026v2.
    ///
    /// This block defines:
    /// - Origin: HUMAN, AI, HYBRID
    /// - GovernanceClass: SOFT, MEDIUM, HARD
    /// The generation script must produce enum discriminants matching
    /// the ALN specification.
  endcontent
endblock
