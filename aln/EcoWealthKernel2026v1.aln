PARTICLE EcoWealthKernel2026v1
ROLE GOVERNANCE
CATEGORY ECOWEALTH
VERSIONTAG 2026v1
TITLE EcoWealth kernel exponents for Ws(Ks,Es,Rs)
DESCRIPTION Freezes α, β, γ for W_s(K_s,E_s,R_s) = E_s^α K_s^β (1-R_s)^γ under the 2026 ecosafety grammar.

FIELDS
kernelid            string   EcoWealthKernel2026v1
lane_scope          string   RESEARCH|EXPPROD|PROD
planecontractid     string   PlaneWeightsShard2026v1
kercontext          string   PhoenixEcoSafetySpine2026v1

# Exponents α, β, γ for K/E/R.
alpha_exponent      f64      # exponent on eco-impact E_s
beta_exponent       f64      # exponent on knowledge K_s
gamma_exponent      f64      # exponent on risk complement (1 - R_s)

# Governance bounds and invariants.
alpha_min           f64
alpha_max           f64
beta_min            f64
beta_max            f64
gamma_min           f64
gamma_max           f64

# Frozen 2026 exponents (example: α=1.0, β=0.5, γ=2.0).
alpha_frozen        f64
beta_frozen         f64
gamma_frozen        f64

# Non-compensation flags and non-offsettable planes must match PlaneWeightsShard2026v1.
noncompensableplanes string   # comma-separated plane ids e.g. "carbon,biodiversity"

# Evidence and signatures.
evidencehex         string
signingdid          string

END

# Canonical 2026v1 record (ALN CSV-style row)
ROW
kernelid=EcoWealthKernel2026v1,
lane_scope=PROD,
planecontractid=PlaneWeightsShard2026v1,
kercontext=PhoenixEcoSafetySpine2026v1,
alpha_exponent=1.0,
beta_exponent=0.5,
gamma_exponent=2.0,
alpha_min=0.5,
alpha_max=2.0,
beta_min=0.0,
beta_max=1.5,
gamma_min=1.0,
gamma_max=3.0,
alpha_frozen=1.0,
beta_frozen=0.5,
gamma_frozen=2.0,
noncompensableplanes=carbon,biodiversity,
evidencehex=hex-EcoWealthKernel2026v1-proof,
signingdid=bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
END
