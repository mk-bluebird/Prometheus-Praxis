# filename: ecorestorationshard/cyboquatic_progress/20260720/aln/BlastRadiusGovernance20260720.aln
# destination: ecorestorationshard/cyboquatic_progress/20260720/aln/BlastRadiusGovernance20260720.aln
# domain: g, non-weaponized blast-radius surcharge governance tied to DID bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7.[file:2][file:13]

particle BlastRadiusGovernance20260720
versiontag 20260720v2
signingdid bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
domain CYBOQUATIC_SURCHARGE_IMPACT
region PHX-CAZ-CEIM
subtaskid PHX-CANAL-BR-2026-07-20
classification NONACTUATING_HYDRO_SAFETY_ONLY

field k_metric      type float required true
field e_metric      type float required true
field r_metric      type float required true
field vt_residual   type float required true
field scope_label   type string required true  # must be HYDRO_SURCHARGE only.
field evidence_hex  type string required true

# Core KER bounds and Lyapunov hint (unchanged safety semantics).[file:13][file:22]
predicate ker_in_unit_interval
expr k_metric >= 0.0 and k_metric <= 1.0
    and e_metric >= 0.0 and e_metric <= 1.0
    and r_metric >= 0.0 and r_metric <= 1.0

predicate vt_contractive_hint
expr vt_residual <= 0.50

# Explicit non-weaponization constraints.[file:13][file:22]
predicate scope_is_hydro_surcharge_only
expr scope_label == "HYDRO_SURCHARGE" and domain == "CYBOQUATIC_SURCHARGE_IMPACT"

predicate no_weaponization
expr classification == "NONACTUATING_HYDRO_SAFETY_ONLY"

# Hard invariant: this particle is invalid if any attempt is made to repurpose
# it outside hydrologic surcharge safety, or into any weapons/offensive frame.[file:13][file:22]
invariant blast_radius_governance_safe_nonweaponized
requires ker_in_unit_interval
    and vt_contractive_hint
    and scope_is_hydro_surcharge_only
    and no_weaponization
