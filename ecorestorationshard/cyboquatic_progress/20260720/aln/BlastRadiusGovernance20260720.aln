particle BlastRadiusGovernance20260720
versiontag 20260720v1
signingdid bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
domain CYBOQUATIC_BLASTRADIUS
region PHX-CAZ-CEIM
subtaskid PHX-CANAL-BR-2026-07-20

field k_metric type float required true
field e_metric type float required true
field r_metric type float required true
field vt_residual type float required true

predicate ker_in_unit_interval
expr k_metric >= 0.0 and k_metric <= 1.0
    and e_metric >= 0.0 and e_metric <= 1.0
    and r_metric >= 0.0 and r_metric <= 1.0

predicate vt_contractive_hint
expr vt_residual <= 0.50

invariant blast_radius_governance_safe
requires ker_in_unit_interval and vt_contractive_hint
