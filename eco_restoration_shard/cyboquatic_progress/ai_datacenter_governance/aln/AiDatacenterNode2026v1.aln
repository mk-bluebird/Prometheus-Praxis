# filename: eco_restoration_shard/cyboquatic_progress/ai_datacenter_governance/aln/AiDatacenterNode2026v1.aln

particle AiDatacenterNode2026v1 {
  signing_did  = "bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7";
  region_code  = "PHX-CAZ-CEIM";
  lane_default = "RESEARCH";

  plane AI_CARBON {
    metric CUE {
      ideal   = 0.05;
      ceiling = 0.40;
      unit    = "kg_CO2_per_kWh";
    }
    metric ECO_PER_JOULE {
      ideal      = 1.0;
      floor      = 0.2;
      unit       = "eco_unit_per_J";
      invert_norm = true;
    }
  }

  plane AI_POWER {
    metric PUE {
      ideal   = 1.05;
      ceiling = 1.40;
      unit    = "ratio";
    }
  }

  plane AI_ECO_RATIO {
    metric ECO_TASK_RATIO {
      min_required = 0.50;
      floor        = 0.20;
      unit         = "fraction";
      invert_norm  = true;
    }
  }

  plane AI_WATER {
    metric WUE {
      ideal   = 0.20;
      ceiling = 1.50;
      unit    = "L_per_kWh";
    }
  }

  plane AI_MATERIALS {
    metric EMBODIED_CO2 {
      ideal   = 0.0;
      ceiling = 100.0;
      unit    = "kg_CO2eq_per_window";
    }
  }

  plane AI_TOPOLOGY {
    metric TOPOLOGY_VIOLATIONS {
      ideal   = 0.0;
      ceiling = 5.0;
      unit    = "count";
    }
  }

  guidance THROUGHPUT {
    metric TOKENS_PER_JOULE {
      ideal = 1_000_000.0;
      unit  = "tokens_per_J";
    }
    metric UTILISATION {
      ideal = 0.90;
      unit  = "fraction";
    }
    metric ERE {
      ideal = 1.0;
      unit  = "fraction";
    }
  }

  ker_engine {
    weight w_cue         = 0.20;
    weight w_eco_per_j   = 0.20;
    weight w_eco_ratio   = 0.15;
    weight w_wue         = 0.15;
    weight w_pue         = 0.10;
    weight w_energy      = 0.05;
    weight w_joule_inf   = 0.05;
    weight w_embodied    = 0.05;
    weight w_heat_reuse  = 0.03;
    weight w_topology    = 0.02;

    function norm_linear(x, ideal, ceiling) {
      if x <= ideal then 0.0
      else clamp01((x - ideal) / (ceiling - ideal))
      end
    }

    function compute_vt(m) -> Vt {
      let r_cue        = norm_linear(m.CUE,             0.05, 0.40);
      let r_eco_j      = if m.ECO_PER_JOULE >= 1.0
                           then 0.0
                           else clamp01((1.0 - m.ECO_PER_JOULE) / (1.0 - 0.2))
                         end;
      let r_eco_ratio  = if m.ECO_TASK_RATIO >= 0.50
                           then 0.0
                           else clamp01((0.50 - m.ECO_TASK_RATIO) / (0.50 - 0.20))
                         end;
      let r_wue        = norm_linear(m.WUE,            0.20, 1.50);
      let r_pue        = norm_linear(m.PUE,            1.05, 1.40);
      let r_energy     = norm_linear(m.ENERGY_INTENSITY, 0.10, 0.50);
      let r_joule_inf  = norm_linear(m.JOULES_PER_INF, 1.0, 10.0);
      let r_embodied   = clamp01(m.EMBODIED_CO2 / 100.0);
      let r_heat_reuse = if m.ERE >= 0.5
                           then 0.0
                           else clamp01((0.5 - m.ERE) / 0.5)
                         end;
      let r_topology   = clamp01(m.TOPOLOGY_VIOLATIONS / 5.0);

      return
        w_cue       * r_cue^2 +
        w_eco_per_j * r_eco_j^2 +
        w_eco_ratio * r_eco_ratio^2 +
        w_wue       * r_wue^2 +
        w_pue       * r_pue^2 +
        w_energy    * r_energy^2 +
        w_joule_inf * r_joule_inf^2 +
        w_embodied  * r_embodied^2 +
        w_heat_reuse* r_heat_reuse^2 +
        w_topology  * r_topology^2;
    }

    function compute_ker(m, vt_prev, vt_curr) {
      let delta_vt   = vt_curr - vt_prev;
      let k_base     = 0.95 - 0.30 * vt_curr - 0.10 * max(0.0, delta_vt);
      let k_boost    = 0.05 * (
                         0.4 * clamp01(m.TOKENS_PER_JOULE / 1_000_000.0) +
                         0.3 * clamp01(m.UTILISATION     / 0.90) +
                         0.3 * clamp01(m.ERE             / 1.0)
                       );
      let K          = clamp01(k_base + k_boost);
      let E          = clamp01(0.93 - 0.25 * vt_curr);
      let R          = clamp01(0.12 + 0.40 * vt_curr + 0.20 * max(0.0, delta_vt));
      return { K = K, E = E, R = R };
    }

    invariant R_ceiling = 0.13;
  }

  chaining {
    evidence_table      = "daily_progress_ai_node";
    evidence_column     = "evidencehex";
    prior_pointer_field = "prior_evidencehex";
  }
}
