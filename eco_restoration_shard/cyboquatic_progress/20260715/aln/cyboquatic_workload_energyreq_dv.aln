  workload_metrics {
    flow_m3s_safe_max   = 5.0;
    head_loss_m_safe_max= 2.0;
    energyreq_j_safe_max= 50000.0;
  }

  governance_notes {
    non_actuating_only = true;
    description = "Phoenix canal cyboquatic workload particle for energyreqJ and ΔVt telemetry, \
                   enabling carbon-negative routing decisions without direct control surfaces.";
    next_research {
      q1 = "Integrate biodegradable compound drag coefficients into energyreqJ to quantify \
            carbon-negative benefits of substrate upgrades.";
      q2 = "Extend vt_residual planes with PFAS fate and cold-survival coordinates from \
            qpudatashard variants, preserving convexity and safestep invariants.";
      q3 = "Calibrate K,E,R thresholds against historical surcharge events to refine \
            admissible workload bands for Phoenix canals.";
    }
  }
