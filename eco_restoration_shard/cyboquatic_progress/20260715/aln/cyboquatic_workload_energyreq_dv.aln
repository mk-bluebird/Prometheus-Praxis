#          bound to DID bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7 with explicit K,E,R.

particle CyboquaticWorkloadEnergyReqDV20260715 {
  signing_did    = "bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7";
  evidence_hex   = "0x20260715PHXENERGYREQDV";
  lane           = "RESEARCH";
  domain         = "cyboquatic_workload";
  subtask_id     = "PHX-CANAL-ENERGYREQDV-20260715";

  # K,E,R triad for this particle, derived from non-actuating workload analysis.
  K = 0.90;  # high knowledge: parameters and residuals within corridor-normalized bands
  E = 0.88;  # strong eco-impact: energyreqJ minimized for target flow/head constraints
  R = 0.10;  # low residual risk: ΔVt positive only in diagnostic regimes, no actuation

  # Lyapunov corridor semantics (aligned with EcoNet grammar).
  vt_residual {
    planes = ["hydraulics", "energy"];
    weights {
      hydraulics = 0.6;
      energy     = 0.4;
    }
    invariant = "V_t1 <= V_t";   # safestep constraint for deployment windows
