  county                 text
  district               text
  campus_id              text
  campus_name            text
  lat                    float
  lon                    float
  twindow_start_utc      text
  twindow_end_utc        text

  context_screwworm_zone text      # NONE,WATCH,INFESTED
  context_livestock_density text   # LOW,MEDIUM,HIGH
  context_vec_index       float    # normalized 0–1 parasite pressure

  school_enrollment       int
  school_level            text      # ELEMENTARY,SECONDARY,MIXED
  has_ag_program          bool
  water_source_type       text      # WELL,MUNICIPAL,OTHER
  hvac_type               text      # CENTRAL-HVAC,PACKAGED-ROOFTOP,OTHER

  parasite_indicator_type text      # FECAL_INDICATOR_ECOLI,HELMINTH_PREVALENCE,NONE
  parasite_indicator_value float
  parasite_indicator_unit text      # MPN_100ML,FRACTION,N_A

  nano_mode               text      # NONE,EXTERNAL_FILTER,SURFACE_COATING,EXTERNAL_DIAGNOSTIC
  nano_parasite_coverage_frac float # 0–1 fraction of relevant surfaces/flows covered
  nano_neuro_binding_score float    # 0–1 proxy; must remain near 0
  nano_material_half_life_days float
  nano_carbon_kg_co2e_year float
  nano_uncertainty_index   float    # rsigma_raw-style scalar before normalization

  r_parasite              float     # 0–1 normalized parasite risk
  r_nano_benefit_gap      float     # 0–1 gap between nano benefit and baseline
  r_neuro                 float     # 0–1 normalized neuro risk
  r_persistence           float     # 0–1 normalized environmental persistence
  r_carbon                float     # 0–1 normalized carbon footprint
  r_sigma                 float     # 0–1 normalized uncertainty

  r_regulatory            float     # 0–1 normalized regulatory risk
  r_consent               float     # 0–1 normalized community consent/trust risk
  r_longterm              float     # 0–1 normalized long-horizon pediatric risk

  vt                      float     # Lyapunov residual for this time window
  ker_k                   float
  ker_e                   float
  ker_r                   float

  kerdeployable           bool      # final gate from Rust ecosafety engine

  deployment_stage        text      # STAGE0_SIM,STAGE1_ADULT,STAGE2_INFRA,STAGE3_SCHOOL_PILOT,STAGE4_NORMALIZED
  lane                    text      # EXP,PILOT,PROD

  corridor_neuro          text      # e.g. NEURO_TIGHT
  corridor_persistence    text      # e.g. PERSIST_BIODEG_FAST
  corridor_carbon         text      # e.g. CARBON_NET_NEGATIVE
  corridor_uncertainty    text      # e.g. UNCERTAINTY_LOW

  regulatory_basis_id     text      # links to EVIDENCE shard: TSCA/EPA/FDA/state analysis
  consent_artifact_id     text      # links to EVIDENCE shard: parental consent & engagement
  monitoring_protocol_id  text      # links to EVIDENCE shard: pediatric monitoring protocol

  evidence_hex            text      # hex hash of primary evidence bundle
  signing_hex             text      # hex signature tied to Bostrom/ALN identity
ENDRECORD

