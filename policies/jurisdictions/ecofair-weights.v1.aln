// File: policies/jurisdictions/ecofair-weights.v1.aln

TITLE ecofair_weights.v1
TABLE ecofair_weights
    jurisdiction_id     : string(32)
    sko_class           : string(64)

    // Weight vector over normalized (E, C, L, R, F). Must sum to 1.0.
    w_energy            : float32
    w_carbon            : float32
    w_latency           : float32
    w_risk              : float32
    w_fair              : float32

    constitutional_basis: string(2048)    // policy text or URL, tribunal IDs
    validity_start_date : date
    validity_end_date   : date
END
