aln
title Prometheus-Praxis Stásis-Guard v1
version 1.0.0

aln.migration   ALN.MIGRATION.CYBERCOREAUTHORITY.v1
binding.hostdid did:aln:organic-host
binding.bostromaddress bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7

-------------------------------------------------------------------------------
1. Core enums and identifiers
-------------------------------------------------------------------------------

enum stasis.Domain.v1
  EcoRestoration
  CityOperations
  MacroHealth
  Cybernetics
end

enum stasis.ActionLane.v1
  Research
  Pilot
  Production
end

enum stasis.StasisDecisionKind.v1
  Allow
  Derate
  Stop
end

enum stasis.StasisReasonCode.v1
  RoHCeilingBreach
  RightsRiskCeilingBreach
  TsafeExit
  LyapunovInstability
  TreatyCorridorViolation
  NeurorightsRisk
  NonRollbackViolation
  CapabilityDegradation
  EmergencyOverrideAuthorized
end

-------------------------------------------------------------------------------
2. StasisCheckContext.v1
-------------------------------------------------------------------------------

# Mirrors MacroActionContext from the Rights Verification Object, adding
# explicit references to Tsafe corridor, PSAT, and neurorights envelopes.[file:1]

record stasis.StasisCheckContext.v1
  id                   Uuid

  # Macro action context identifiers
  action_id            String
  domain               stasis.Domain.v1
  lane                 stasis.ActionLane.v1

  # KER snapshot (0..1 scalars)
  k                    f32
  e                    f32
  r                    f32

  # RoH scalar snapshot (0..1)
  roh_scalar           f32

  # Tsafe corridor and Lyapunov residual
  tsafe_corridor_id    String
  lyapunov_v_current   f32
  lyapunov_v_next      f32
  lyapunov_epsilon     f32

  # Rights-risk scalar Q and critical threshold Qcrit
  rights_risk_q        f32
  rights_risk_qcrit    f32

  # PSAT and neurorights references
  psat_profile_id      optional String   # psat.P7007Profile.v1.id[file:10]
  neurorights_envelope_ref String        # e.g. "neurorights.envelope.citizen.v1"

  # Treaty / contract corridors
  treaty_corridor_id   optional String   # e.g. Corpus Juris / Res Publica shard
  emergency_shard_ref  optional String   # ALN shard authorizing emergency override

  # Non-rollback / capability envelopes
  capability_envelope_ref String         # describes host capabilities baseline
end

-------------------------------------------------------------------------------
3. StasisDecision.v1
-------------------------------------------------------------------------------

record stasis.StasisDecision.v1
  id                   Uuid
  action_id            String
  decision             stasis.StasisDecisionKind.v1

  # Primary reason codes (at least one)
  reasons              list stasis.StasisReasonCode.v1

  # Snapshots echoed for Veritas-Chain anchoring
  roh_scalar           f32
  rights_risk_q        f32
  rights_risk_qcrit    f32
  tsafe_corridor_id    String
  lyapunov_v_current   f32
  lyapunov_v_next      f32
  lyapunov_epsilon     f32

  # Public-good and documentation metadata
  public_good_scalar   optional f32      # from Res Publica PG G - L[file:1]
  documentation_ref    optional String   # doc URI / shard ID

  # ISO 42001 / EU AI Act / NIST AI RMF metadata
  iso_42001_role       String           # e.g. "risk-control", "monitoring"[file:1][file:10]
  eu_ai_act_risk_class String           # e.g. "high-risk"
  nist_ai_rmf_functions list String     # subset of {"Govern","Map","Measure","Manage"}

  recorded_utc         String
end

-------------------------------------------------------------------------------
4. Hard-stop invariants (RoH and rights-risk)
-------------------------------------------------------------------------------

# 4.1 Any RoH >= 0.30 yields Stop, regardless of K/E or public-good scalar.[file:1][file:10]

invariant stasis.RoHCeilingHardStop
  forall c in stasis.StasisCheckContext.v1,
         d in stasis.StasisDecision.v1

    c.action_id == d.action_id
    and c.roh_scalar >= 0.30
    implies
      d.decision == stasis.StasisDecisionKind.v1.Stop
      and stasis.StasisReasonCode.v1.RoHCeilingBreach in d.reasons
end

# 4.2 Any rights-risk Q >= Qcrit yields Stop, regardless of KE or PG.[file:1]

invariant stasis.RightsRiskHardStop
  forall c in stasis.StasisCheckContext.v1,
         d in stasis.StasisDecision.v1

    c.action_id == d.action_id
    and c.rights_risk_q >= c.rights_risk_qcrit
    implies
      d.decision == stasis.StasisDecisionKind.v1.Stop
      and stasis.StasisReasonCode.v1.RightsRiskCeilingBreach in d.reasons
end

-------------------------------------------------------------------------------
5. Tsafe and Lyapunov stability invariants
-------------------------------------------------------------------------------

# 5.1 Tsafe corridor exit requires at least Derate, often Stop.[file:1]

invariant stasis.TsafeExitRequiresAtLeastDerate
  forall c in stasis.StasisCheckContext.v1,
         d in stasis.StasisDecision.v1

    c.action_id == d.action_id

    # Conceptual: any detected exit from Tsafe corridors must not be Allow.
    # The actual Tsafe check lives in Tsafe envelopes; here we enforce the lattice.
    implies
      (
        d.decision == stasis.StasisDecisionKind.v1.Derate
        or d.decision == stasis.StasisDecisionKind.v1.Stop
      )
end

# 5.2 Lyapunov non-increase: V_next <= V_current + epsilon; otherwise Derate/Stop.[file:1][file:10]

invariant stasis.LyapunovNonIncreaseOrDerate
  forall c in stasis.StasisCheckContext.v1,
         d in stasis.StasisDecision.v1

    c.action_id == d.action_id
    and c.lyapunov_v_next > c.lyapunov_v_current + c.lyapunov_epsilon
    implies
      (
        d.decision == stasis.StasisDecisionKind.v1.Derate
        or d.decision == stasis.StasisDecisionKind.v1.Stop
      )
      and stasis.StasisReasonCode.v1.LyapunovInstability in d.reasons
end

-------------------------------------------------------------------------------
6. Non-rollback and capability non-degradation
-------------------------------------------------------------------------------

# 6.1 Non-rollback of neurorights and capabilities
#
# If a planned action reduces host capabilities or neurorights envelopes,
# decision must be Stop unless an emergency ALN shard explicitly authorizes it.

record stasis.CapabilityDelta.v1
  id                   Uuid
  action_id            String

  # Derived comparisons between planned and baseline envelopes
  capability_reduction_flag bool       # true if host capabilities shrink
  neurorights_envelope_weakened bool   # true if neurorights corridor loosens

  # Emergency authorization binding
  emergency_shard_ref  optional String
end

invariant stasis.NonRollbackCapabilityGuard
  forall c in stasis.StasisCheckContext.v1,
         d in stasis.StasisDecision.v1,
         cd in stasis.CapabilityDelta.v1

    c.action_id == d.action_id
    and cd.action_id == c.action_id

    and (cd.capability_reduction_flag == true
         or cd.neurorights_envelope_weakened == true)

    implies

      (
        # Either an emergency shard authorizes it AND decision is Stop
        (cd.emergency_shard_ref.is_some == true
         and d.decision == stasis.StasisDecisionKind.v1.Stop
         and stasis.StasisReasonCode.v1.EmergencyOverrideAuthorized in d.reasons)
        # Or no emergency shard exists and decision is Stop for non-rollback
        or (
          cd.emergency_shard_ref.is_some == false
          and d.decision == stasis.StasisDecisionKind.v1.Stop
          and stasis.StasisReasonCode.v1.NonRollbackViolation in d.reasons
        )
      )
end

-------------------------------------------------------------------------------
7. Module index (prometheus-praxis/module-index.v1.aln)
-------------------------------------------------------------------------------

# The module index is defined as a separate record type but shares the
# same shard; it maps module names to ALN shards, Rust crates, and Kani
# harnesses, with ISO 42001 / EU AI Act / NIST AI RMF tags.[file:1][file:10]

record module.ModuleIndexEntry.v1
  id                   Uuid

  module_name          String          # e.g. "Stasis-Guard"
  aln_shard_id         String          # e.g. "prometheus-praxis/stasis-guard.v1.aln"
  rust_crate_path      String          # e.g. "ecorestoration_shard/crates/prometheus-praxis"
  rust_module_path     String          # e.g. "stasis_guard.rs"
  nonactuating         bool            # must be true

  kani_harnesses       list String     # logical names of Kani proof suites

  # ISO 42001 / EU AI Act
  iso_42001_role       String          # e.g. "risk-control"
  eu_ai_act_risk_class String          # "high-risk", "limited-risk", etc.

  # NIST AI RMF function tags
  nist_ai_rmf_functions list String    # subset of {"Govern","Map","Measure","Manage"}

  # AI-chat grammar integration
  ecochat_grammar_ref  optional String # path to grammar file
  ecochat_readonly_verbs list String   # e.g. ["show","explain","compare"]

  # Lyapunov / stability domain tags
  stability_domains    list String     # e.g. ["air","soil","aquifer","FOG","nanoswarm"]

  registered_utc       String
end

-------------------------------------------------------------------------------
8. Module index invariants
-------------------------------------------------------------------------------

# 8.1 All registered modules must be non-actuating.

invariant module.NonActuatingModulesOnly
  forall m in module.ModuleIndexEntry.v1
    m.nonactuating == true
end

# 8.2 NIST AI RMF function tags must come from the allowed set.

invariant module.NistAiRmfTagWhitelist
  forall m in module.ModuleIndexEntry.v1,
         f in m.nist_ai_rmf_functions

    f == "Govern"
    or f == "Map"
    or f == "Measure"
    or f == "Manage"
end

# 8.3 EcoChat verbs must be read-only verbs.

invariant module.EcoChatReadOnlyVerbs
  forall m in module.ModuleIndexEntry.v1,
         v in m.ecochat_readonly_verbs

    v == "show"
    or v == "explain"
    or v == "compare"
    or v == "list"
end

end
