aln
title Prometheus-Praxis Kairos-Executor v1
version 1.0.0

aln.migration ALN.MIGRATION.CYBERCOREAUTHORITY.v1
binding.hostdid did:aln:organic-host
binding.bostromaddress bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7

-------------------------------------------------------------------------------
1. Core enums: domains, lanes, status
-------------------------------------------------------------------------------

enum kairos.ActionDomain.v1
  EcoRestoration
  CityOperations
  MacroHealth
  Cybernetics
  ResearchPilot
end

enum kairos.ActionLane.v1
  RESEARCH
  GOV
  EXPPROD
end

enum kairos.WindowStatus.v1
  Pending
  Scheduled
  Executing
  Completed
  Cancelled
end

-------------------------------------------------------------------------------
2. KER + RoH lane profile references
-------------------------------------------------------------------------------

record kairos.LaneKerProfileRef.v1
  id                    Uuid
  lane                  kairos.ActionLane.v1
  ker_profile_id        String      # e.g. workspace.metadata.ker.lane.RESEARCH
  roh_ceiling           f32         # must equal global roh ceiling (e.g. 0.30)
  k_min                 f32         # lane-specific K floor
  e_min                 f32         # lane-specific E floor
  r_max                 f32         # lane-specific R ceiling
end

-------------------------------------------------------------------------------
3. Kairos window and decision schema
-------------------------------------------------------------------------------

record kairos.KairosWindow.v1
  id                    Uuid
  domain                kairos.ActionDomain.v1
  lane                  kairos.ActionLane.v1

  action_id             String       # MacroActionContext.id
  site_or_host_id       String       # site id, host DID, or corridor id

  earliest_start_utc    String       # ISO-8601 UTC
  latest_start_utc      String       # ISO-8601 UTC
  hard_deadline_utc     String       # ISO-8601 UTC

  ker_profile_ref_id    Uuid         # kairos.LaneKerProfileRef.v1.id
  ker_snapshot_id       String       # KER snapshot ALN id
  roh_snapshot_id       String       # RoH snapshot ALN id

  lyapunov_envelope_id  String       # Lyapunov envelope ALN id
  tsafe_corridor_id     String       # Tsafe corridor ALN id

  psat_profile_id       String       # psat.P7007Profile.v1.id when applicable

  created_utc           String
  status                kairos.WindowStatus.v1
end

record kairos.KairosDecision.v1
  id                    Uuid
  window_id             Uuid
  chosen_start_utc      String       # scheduled start time
  domain                kairos.ActionDomain.v1
  lane                  kairos.ActionLane.v1

  governance_decision   String       # Allow, Derate, Stop (binds to Rights Kernel)
  reason_code           String       # e.g. "KER_WITHIN_LANE", "ROH_CEILING", "LYAP_DRIFT"

  ker_snapshot_id       String
  roh_snapshot_id       String
  lyapunov_residual_id  String       # snapshot of V_next - V_current
  tsafe_corridor_id     String
  psat_profile_id       String

  veritas_anchor_id     String       # Veritas-Chain anchor
  janus_verifier_id     String       # Janus-Veritas check id

  created_utc           String
end

-------------------------------------------------------------------------------
4. Residual parameters (Lyapunov and KER)
-------------------------------------------------------------------------------

record kairos.ResidualConfig.v1
  id                    Uuid

  vref                  f32          # reference Lyapunov value
  max_delta_v           f32          # |V_next - V_current| <= max_delta_v
  min_slope             f32          # lower bound on dV/dt
  max_slope             f32          # upper bound on dV/dt (<= 0 for non-increase)

  wk                    f32          # weight for knowledge residual
  we                    f32          # weight for eco-impact residual
  wr                    f32          # weight for risk residual

  roh_residual_epsilon  f32          # allowed RoH residual band
end

record kairos.KerResidualSnapshot.v1
  id                    Uuid
  window_id             Uuid

  k_target              f32
  k_actual              f32
  e_target              f32
  e_actual              f32
  r_target              f32
  r_actual              f32

  rK                    f32          # k_target - k_actual
  rE                    f32          # e_target - e_actual
  rR                    f32          # r_actual - r_target

  rKER                  f32          # combined residual
end

record kairos.LyapunovResidualSnapshot.v1
  id                    Uuid
  window_id             Uuid

  V_current             f32
  V_next                f32
  delta_V               f32          # V_next - V_current
end

-------------------------------------------------------------------------------
5. Invariants: KER lanes, RoH ceiling, Lyapunov non-increase
-------------------------------------------------------------------------------

invariant kairos.GlobalRohCeiling
  # Any Kairos window must not target a lane with RoH ceiling above the global ALN RoH ceiling.
  forall w in kairos.KairosWindow.v1
    exists p in kairos.LaneKerProfileRef.v1
      w.ker_profile_ref_id == p.id
      and w.lane == p.lane
      and p.roh_ceiling <= 0.30
end

invariant kairos.LaneKerThresholds
  # Lane-specific KER thresholds must be consistent with workspace.metadata.ker
  # (checked by Rust bindings and CI; here we assert structural consistency).
  forall p in kairos.LaneKerProfileRef.v1
    p.k_min  >= 0.0
    and p.e_min  >= 0.0
    and p.r_max  >= 0.0
    and p.r_max  <= p.roh_ceiling
end

invariant kairos.KerResidualBound
  # For each Kairos window, the KER residual must be computed using the shared weights and respect RoH residual bounds.
  forall r in kairos.KerResidualSnapshot.v1
    exists c in kairos.ResidualConfig.v1
      r.rKER == c.wk * r.rK + c.we * r.rE + c.wr * r.rR
      and r.rR <= c.roh_residual_epsilon
end

invariant kairos.LyapunovNonIncrease
  # Lyapunov residual must respect non-increase with bounded noise.
  forall s in kairos.LyapunovResidualSnapshot.v1
    exists c in kairos.ResidualConfig.v1
      s.delta_V == s.V_next - s.V_current
      and s.delta_V <= c.max_delta_v
      and s.V_next <= s.V_current + c.max_delta_v
      and s.V_next <= s.V_current      # enforce non-increase (safety-first)
end

-------------------------------------------------------------------------------
6. Scheduling invariants: only safe windows can be Scheduled
-------------------------------------------------------------------------------

invariant kairos.ScheduleOnlyWithinKerAndRoh
  # A window may reach Scheduled only if KER and RoH are within lane thresholds.
  forall w in kairos.KairosWindow.v1
    w.status == kairos.WindowStatus.v1.Scheduled implies (
      exists p in kairos.LaneKerProfileRef.v1,
             r in kairos.KerResidualSnapshot.v1
        w.ker_profile_ref_id == p.id
        and r.window_id == w.id
        and r.k_actual >= p.k_min
        and r.e_actual >= p.e_min
        and r.r_actual <= p.r_max
    )
end

invariant kairos.ScheduleOnlyWithinRohCeiling
  # Scheduled windows must respect the global RoH ceiling regardless of K/E or public-good metrics.
  forall w in kairos.KairosWindow.v1
    w.status == kairos.WindowStatus.v1.Scheduled implies (
      exists r in kairos.KerResidualSnapshot.v1
        r.window_id == w.id
        and r.r_actual <= 0.30
    )
end

invariant kairos.ScheduleOnlyWithLyapunovNonIncrease
  # Scheduled windows must maintain Lyapunov non-increase within configured residual bounds.
  forall w in kairos.KairosWindow.v1
    w.status == kairos.WindowStatus.v1.Scheduled implies (
      exists s in kairos.LyapunovResidualSnapshot.v1,
             c in kairos.ResidualConfig.v1
        s.window_id == w.id
        and s.delta_V == s.V_next - s.V_current
        and s.delta_V <= c.max_delta_v
        and s.V_next <= s.V_current
    )
end

-------------------------------------------------------------------------------
7. Governance bindings: Rights Kernel, PSAT, Veritas
-------------------------------------------------------------------------------

record kairos.GovernanceBinding.v1
  id                    Uuid
  window_id             Uuid
  rights_kernel_shard   String       # Rights Verification Object shard id
  nomos_enforcer_shard  String       # Nomos-Enforcer shard id
  psat_profile_id       String       # psat.P7007Profile.v1.id (if applicable)
  veritas_anchor_id     String       # Veritas-Chain anchor
  janus_verifier_id     String       # Janus-Veritas id
end

invariant kairos.GovernanceBindingRequiredForDecision
  # Any KairosDecision must be backed by governance bindings and Veritas anchors.
  forall d in kairos.KairosDecision.v1
    exists g in kairos.GovernanceBinding.v1
      d.window_id == g.window_id
      and d.veritas_anchor_id == g.veritas_anchor_id
      and d.janus_verifier_id  == g.janus_verifier_id
end

invariant kairos.PsatRequiredForHighRiskLanes
  # For GOV and EXPPROD lanes touching bodies or critical eco/city infrastructure, a PSAT profile must be present.
  forall w in kairos.KairosWindow.v1
    (w.lane == kairos.ActionLane.v1.GOV
     or w.lane == kairos.ActionLane.v1.EXPPROD) implies
      exists g in kairos.GovernanceBinding.v1
        g.window_id == w.id
        and g.psat_profile_id != ""
end

end
