version,v1.0.0

host.did,did:alnorganic-host
bostrom.address,bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
aln.migration.authority,ALN.MIGRATION.CYBERCOREAUTHORITY.v1

# Registry header: every row below is a first-class, evidence-bound metric.
schema.id,nanorobotics.obs.metrics.schema.v1
schema.role,metrics-to-governance-alignment
schema.domain,Prometheus-Praxis.nanoswarm.cyboquatic

# Columns:
# metric.name    : Prometheus metric identifier.
# metric.type    : gauge | counter | histogram.
# labels         : canonical label keys.
# units          : physical or normalized units.
# role           : realtime-safety | posthoc-evolution.
# rust.source    : Rust type or module that computes the value.
# aln.source     : ALN shard/field that defines ceilings, bands, or semantics.
# evidence.bundle: hex/evidence family that backs calibration or thresholds.

ROW
metric.name,prompraxis_roh_host
metric.type,gauge
labels,host_id mission_id lane
units,normalized-risk-0-1
role,realtime-safety
