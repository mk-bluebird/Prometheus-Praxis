aln

SECTION,SACRIFICE-ZONE-SPEC
version,v1.0.0

# Host / authority binding (ALNv2 owner binding)
hostdid,OrganicCPU
bostromaddress,bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
aln.migration.authority,ALN.MIGRATION.CYBERCOREAUTHORITY.v1

# Doctrine and evolution flags
forbid.downgrade,true
monotone.tightening.only,true

# Semantic axis
axis.label,sacrifice.zone
axis.description,Sacrifice zones and exclusion corridors for high-contamination, structurally uninhabitable regions, with KER/RoH and pollinator/wildlife invariants.

# Global invariants (documentation-grade here; enforced in Rust/Kani)
invariant.domain,Actions referencing a SacrificeZoneSpec row must treat it as a governance envelope, not a free-form coordinate.
invariant.roh.global.ceiling,Resilience-of-Health RoH ceiling for any sacrifice zone must not exceed 0.30 and is non-offsettable.
invariant.monotone,Any accepted update for a given zone-id must not increase roh_ceiling, rmax, or contamination ceilings, and must not relax biosphere protection flags or sovereignty tags.
invariant.geo.required,No nanoswarm or cyboquatic planning may target a zone without geometry_ref and proof_hash_hex present and validated.
invariant.pollinator.hardstop,Zones with non-zero pollinator or wildlife activity cannot be treated as lifeless; nanoswarm actuation must be explicitly pollinator- and wildlife-safe or restricted to sealed micro-sites.

# Column schema (ALNv2 flat schema; one row = one Sacrifice Zone)
# zone_id                - Stable identifier for the sacrifice zone (e.g., SZ.CHERNO.UA.001, SZ.MARVAULT.PHX.001).
# region_id              - Region / corridor binding (watershed_id, district_id, or corridor_id from smartcity/eco_restoration catalogs).
# authority_id           - DID or authority identifier (UNEP, EPA, local regulator, etc.).
# geometry_ref           - Reference to ALN/GeoJSON shard or grid index set defining the zone geometry.
# exclusion_status       - NONE, HUMAN_EXCLUSION, INDUSTRIAL_EXCLUSION, FULL_EXCLUSION.
# evidence_bundle_id     - Reference to evidence bundle shard (measurements, maps, legal orders).
# proof_hash_hex         - Hex hash of the geo-proof bundle anchored in Veritas/Organichain.
#
# primary_class          - RADIATION, HEAVY_METALS, PERSISTENT_ORGANICS, HYDROCARBONS, MICROPLASTICS, AIR_POLLUTION, MULTI_MODAL.
# secondary_classes_json - JSON/ALN list of secondary contamination classes.
# contamination_radiation      - 0..1 normalized radiation contamination index.
# contamination_heavy_metals   - 0..1 normalized heavy metals contamination index.
# contamination_organics       - 0..1 normalized persistent organics index.
# contamination_microplastics  - 0..1 normalized microplastics index.
# contamination_air            - 0..1 normalized air pollution index.
# contamination_other          - 0..1 generic index for other contaminants.
#
# pollinator_activity     - NONE_DETECTED, SPARSE, MODERATE, HIGH.
# wildlife_activity       - NONE_DETECTED, SPARSE, MODERATE, HIGH.
# biosignal_proof_id      - Reference to biosurvey / VitalNet shard documenting life presence/absence.
#
# lane                   - RESEARCH, PILOT, PRODUCTION, CITY_CRITICAL (Prometheus-Praxis lanes).
# roh_ceiling            - 0..1 RoH ceiling for actions in this zone (must be ≤ 0.30).
# kmin                   - 0..1 minimum Knowledge K for actions referencing this zone.
# emin                   - 0..1 minimum EcoImpact E for actions referencing this zone.
# rmax                   - 0..1 maximum Risk-of-Harm R (must be ≤ roh_ceiling).
#
# neurorights_envelope_id - Reference to neurorights envelope shard if any neuro/cyber systems are relevant.
# sovereignty_tags_json   - JSON/ALN list: e.g., ["INDIGENOUS_LAND","CONFLICT_ZONE","SACRED_SITE"].
# notes                   - Free-text, short description; not used in guard logic but visible in dashboards.

columns,zone_id,region_id,authority_id,geometry_ref,exclusion_status,evidence_bundle_id,proof_hash_hex,primary_class,secondary_classes_json,contamination_radiation,contamination_heavy_metals,contamination_organics,contamination_microplastics,contamination_air,contamination_other,pollinator_activity,wildlife_activity,biosignal_proof_id,lane,roh_ceiling,kmin,emin,rmax,neurorights_envelope_id,sovereignty_tags_json,notes

