spec BeeCorridorWideningRejection2026v1 {

  meta {
    version          = "2026v1"
    domain           = "bee-corridor-envelope"
    ecosafety_layer  = "PollinatorCorridorKernel"
    rule_id          = "no_widening_when_upgrading"
    knowledge_factor = 0.94
    eco_impact_value = 0.97
    rationale        = "Formally prove that bee corridor upgrades cannot widen envelopes; generate Rust integration test that must fail on attempted widening."
  }

  # ------------------------------------------------------------------
  # Corridor envelope model
  # ------------------------------------------------------------------

  corridor BeeCorridorEnvelope {
    field corridor_id       : string
    field centerline_km     : float
    field width_m           : float
    field quality_band      : string   # "baseline", "enhanced", "regenerative"
    field created_at_utc    : string
    field last_upgrade_utc  : string
  }

  upgrade BeeCorridorUpgrade {
    field from_corridor_id : string
    field to_corridor_id   : string
    field requested_width_m: float
    field requested_band   : string    # target quality_band
    field applied_at_utc   : string
  }

  # ------------------------------------------------------------------
  # Rule: no widening when upgrading
  #
  # Informal: When upgrading a bee corridor (quality_band increases),
  # the width_m must not increase; equal or narrower envelopes are
  # allowed, but widening is forbidden.
  # ------------------------------------------------------------------

  rule no_widening_when_upgrading {
    given old : BeeCorridorEnvelope
    given new : BeeCorridorEnvelope
    when old.corridor_id == new.corridor_id
    and  old.quality_band != new.quality_band
    and  quality_rank(new.quality_band) > quality_rank(old.quality_band)
    require new.width_m <= old.width_m
    reason = "Upgrades must improve nectar/pollen quality, not expand physical envelope; widening risks non-target impacts."
  }

  # ------------------------------------------------------------------
  # Quality band ranking (monotone ordering)
  # ------------------------------------------------------------------

  fn quality_rank(band: string) -> int {
    match band {
      "baseline"     -> 0
      "enhanced"     -> 1
      "regenerative" -> 2
      _              -> -1
    }
  }

  # ------------------------------------------------------------------
  # Scenario: attempted widening on upgrade (formal rejection)
  #
  # We construct a scenario where the new corridor has strictly
  # larger width_m and strictly higher quality_band rank.
  # The rule no_widening_when_upgrading must reject this scenario.
  # ------------------------------------------------------------------

  scenario BeeCorridorWideningRejection2026v1 {

    given baseline_corridor BeeCorridorEnvelope {
      corridor_id      = "bee_corridor_nhai_2026_phx_demo"
      centerline_km    = 12.5
      width_m          = 30.0
      quality_band     = "baseline"
      created_at_utc   = "2026-02-17T10:00:00Z"
      last_upgrade_utc = "2026-02-17T10:00:00Z"
    }

    given attempted_upgrade BeeCorridorEnvelope {
      corridor_id      = "bee_corridor_nhai_2026_phx_demo"
      centerline_km    = 12.5
      width_m          = 40.0   # widened by +10 m
      quality_band     = "enhanced"
      created_at_utc   = "2026-02-17T10:00:00Z"
      last_upgrade_utc = "2026-05-01T08:00:00Z"
    }

    assert quality_rank(attempted_upgrade.quality_band) > quality_rank(baseline_corridor.quality_band)
    assert attempted_upgrade.width_m > baseline_corridor.width_m

    # Formal rejection: applying the rule must fail
    expect_violation no_widening_when_upgrading(baseline_corridor, attempted_upgrade) {
      violation_code  = "BEE_CORRIDOR_WIDTH_UPGRADE_FORBIDDEN"
      violation_msg   = "Upgrading bee corridor from baseline to enhanced with increased width_m is forbidden by no_widening_when_upgrading."
    }
  }

  # ------------------------------------------------------------------
  # Rust integration test generation
  #
  # We auto-generate a Rust test module that:
  #  - constructs the baseline and attempted upgrade envelopes,
  #  - invokes the corridor upgrade validator,
  #  - asserts that widening leads to an error with the expected code.
  # ------------------------------------------------------------------

  rust_test BeeCorridorWideningRejectionTests {
    target_crate = "bee_corridor_kernel"
    rust_version = "1.85"
    edition      = "2024"

    derives      = ["Debug", "Clone", "serde::Serialize", "serde::Deserialize"]

    # Map ALN types to Rust types
    map BeeCorridorEnvelope -> "BeeCorridorEnvelope"
    map BeeCorridorUpgrade  -> "BeeCorridorUpgrade"

    module_name = "bee_corridor_widening_rejection_tests"

    test no_widening_when_upgrading_rejects_widening {
      rust = """
use bee_corridor_kernel::model::{BeeCorridorEnvelope, QualityBand};
use bee_corridor_kernel::rules::{validate_no_widening_when_upgrading, RuleViolation};

#[test]
fn no_widening_when_upgrading_rejects_widening() {
    let baseline = BeeCorridorEnvelope {
        corridor_id: String::from("bee_corridor_nhai_2026_phx_demo"),
        centerline_km: 12.5_f64,
        width_m: 30.0_f64,
        quality_band: QualityBand::Baseline,
        created_at_utc: String::from("2026-02-17T10:00:00Z"),
        last_upgrade_utc: String::from("2026-02-17T10:00:00Z"),
    };

    let upgraded = BeeCorridorEnvelope {
        corridor_id: String::from("bee_corridor_nhai_2026_phx_demo"),
        centerline_km: 12.5_f64,
        width_m: 40.0_f64, // widening
        quality_band: QualityBand::Enhanced,
        created_at_utc: String::from("2026-02-17T10:00:00Z"),
        last_upgrade_utc: String::from("2026-05-01T08:00:00Z"),
    };

    // Sanity checks on the scenario
    assert!(upgraded.width_m > baseline.width_m);
    assert!(upgraded.quality_band.rank() > baseline.quality_band.rank());

    // Rule must reject this attempted widening
    match validate_no_widening_when_upgrading(&baseline, &upgraded) {
        Ok(_) => panic!("Expected no_widening_when_upgrading to reject widening upgrade, but it returned Ok"),
        Err(violation) => {
            assert_eq!(violation.code, "BEE_CORRIDOR_WIDTH_UPGRADE_FORBIDDEN");
            assert!(
                violation.message.contains("no_widening_when_upgrading"),
                "Violation message did not mention rule name: {}",
                violation.message
            );
        }
    }
}
      """
    }
  }
}
