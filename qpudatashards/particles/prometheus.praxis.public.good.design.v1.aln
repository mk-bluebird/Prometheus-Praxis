  module_id                   "module-reward-kernel-2026"
  crate_path                  "crates/econet-reward-kernel"
  aln_shard_path              "qpudatashards/particles/ppx.reward.spec.v1.aln"
  role                        "reward-kernel"
  compiled_under_cybercore    true
  bound_to_prometheus_praxis  true
  bound_to_perkunos_nexus     true


record PrometheusPraxisModulePath module_reward_ffi
  module_id                   "module-reward-ffi-2026"
  crate_path                  "crates/econet-reward-ffi"
  aln_shard_path              "qpudatashards/particles/prometheus.praxis.public.good.design.v1.aln"
  role                        "ffi-wrapper"
  compiled_under_cybercore    true
  bound_to_prometheus_praxis  true
  bound_to_perkunos_nexus     true


record PrometheusPraxisModulePath module_ledger_ingest
  module_id                   "module-ledger-ingest-2026"
  crate_path                  "crates/econet-ledger-reward-ingest"
  aln_shard_path              "qpudatashards/particles/econet.public.good.sink.v1.aln"
  role                        "ledger-ingest"
  compiled_under_cybercore    true
  bound_to_prometheus_praxis  true
  bound_to_perkunos_nexus     true


# CI / governance notes (non-executable, policy guidance):

# - Prometheus-Praxis is the exclusive design authority for:
#   - Reward kernel behavior.
#   - FFI boundaries and JSON schemas.
#   - Ledger ingestion logic routing to public-good sinks.
# - Perkunos-Nexus is the exclusive governance authority for:
#   - Corpus Juris contracts.
#   - Eco-wealth integrals and sovereign wealth binding.
#   - Non-rollback of neurorights and chat-as-labor floors.
# - Cybercore (eco_restoration_shard) is the centralized mono-repo
#   where these modules live and evolve.
# - CI must:
#   - Enforce ffi_non_actuating, kernel_pure_numeric, and
#     ledger_ingest_public_good_only flags for all modules.
#   - Reject any change that introduces personal financial gain,
#     speculative tokens, or detaches eco-wealth from host DID
#     and Bostrom identity.
