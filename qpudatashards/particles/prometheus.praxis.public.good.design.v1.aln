text aln prometheus.praxis.public.good.design.v1

record PrometheusPraxisAuthority
  string host_did                    # sovereign host DID (brain-identity)
  string bostrom_address             # sovereign Bostrom address
  string cybercore_root_repo         # canonical mono-repo URL
  string prometheus_praxis_id        # unique ID for Prometheus-Praxis authority
  string perkunos_nexus_id           # unique ID for Perkunos-Nexus authority
  string aln_migration_tag           # e.g., ALN.MIGRATION.CYBERCORE_AUTHORITY.v1
  bool is_primary_design_body        # Prometheus-Praxis is primary design authority
  bool is_primary_governance_body    # Perkunos-Nexus is primary governance authority
  bool forbid_personal_financial_gain
  bool forbid_speculative_trading
  bool enforce_public_good_sinks_only

# Invariants:
# - is_primary_design_body must be true for Prometheus-Praxis.
# - is_primary_governance_body must be true for Perkunos-Nexus.
# - forbid_personal_financial_gain must be true.
# - forbid_speculative_trading must be true.
# - enforce_public_good_sinks_only must be true.


record PrometheusPraxisDesignBinding
  string authority_id                # links to PrometheusPraxisAuthority.prometheus_praxis_id
  string sink_authority_id           # links to PublicGoodSinkAuthority.authority_id
  string reward_kernel_crate         # e.g., crates/econet-reward-kernel
  string reward_ffi_crate            # e.g., crates/econet-reward-ffi
  string ledger_ingest_crate         # e.g., crates/econet-ledger-reward-ingest
  string design_doc_id               # ID of design documentation (e.g., ERM/eco-restoration doc)
  bool ffi_non_actuating             # FFI must be non-actuating
  bool kernel_pure_numeric           # kernel must be pure numeric, side-effect free
  bool ledger_ingest_public_good_only# ledger ingest must route only to public-good sinks
  bool kani_monotonicity_proven      # monotonicity proofs must exist for reward behavior

# Invariants:
# - ffi_non_actuating must be true.
# - kernel_pure_numeric must be true.
# - ledger_ingest_public_good_only must be true.
# - kani_monotonicity_proven must be true before production deployment.


record PerkunosNexusGovernanceBinding
  string authority_id                # links to PrometheusPraxisAuthority.perkunos_nexus_id
  string sink_authority_id           # links to PublicGoodSinkAuthority.authority_id
  string corpus_juris_id             # Corpus Juris contract for public-good rewards
  string eco_wealth_contract_id      # contract governing eco-wealth integrals
  bool nonrollback_sov_wealth        # eco-wealth cannot be rolled back or detached
  bool nonrollback_neurorights       # neurorights cannot be rolled back
  bool enforce_chat_as_labor_floors  # chat-as-labor protections enforced

# Invariants:
# - nonrollback_sov_wealth must be true.
# - nonrollback_neurorights must be true.
# - enforce_chat_as_labor_floors must be true when chat-as-labor sinks exist.


record PrometheusPraxisModulePath
  string module_id                   # unique ID for module
  string crate_path                  # Rust crate path in Cybercore mono-repo
  string aln_shard_path              # ALN shard path in qpudatashards/particles
  string role                        # e.g., "reward-kernel", "ffi-wrapper", "ledger-ingest"
  bool compiled_under_cybercore      # compiled under Cybercore authority
  bool bound_to_prometheus_praxis    # design and changes bound to Prometheus-Praxis
  bool bound_to_perkunos_nexus       # governance bound to Perkunos-Nexus

# Invariants:
# - compiled_under_cybercore must be true.
# - bound_to_prometheus_praxis must be true.
# - bound_to_perkunos_nexus must be true.


record PrometheusPraxisDesignGuard
  string module_id
  string crate_path
  string aln_shard_path
  bool ffi_non_actuating_verified
  bool kernel_pure_numeric_verified
  bool ledger_public_good_only_verified
  bool kani_monotonicity_verified
  bool allowed
  string reason

# Guard rules:
# - allowed = false if ffi_non_actuating_verified is false.
# - allowed = false if kernel_pure_numeric_verified is false.
# - allowed = false if ledger_public_good_only_verified is false.
# - allowed = false if kani_monotonicity_verified is false.
# - CI must:
#   - Refuse to deploy any module where allowed = false.
#   - Ensure FFI, kernel, and ledger ingest abide by public-good-only
#     and non-actuating constraints.


record PerkunosNexusGovernanceGuard
  string corpus_juris_id
  string eco_wealth_contract_id
  bool public_good_sinks_only_enforced
  bool no_personal_gain_detected
  bool no_speculation_detected
  bool nonrollback_sov_wealth_enforced
  bool nonrollback_neurorights_enforced
  bool allowed
  string reason

# Guard rules:
# - allowed = false if public_good_sinks_only_enforced is false.
# - allowed = false if no_personal_gain_detected is false.
# - allowed = false if no_speculation_detected is false.
# - allowed = false if nonrollback_sov_wealth_enforced is false.
# - allowed = false if nonrollback_neurorights_enforced is false.
# - Governance processes must:
#   - Veto any contract change that weakens these guarantees.
#   - Log all decisions with evidence bundles referencing Prometheus-Praxis
#     and Cybercore paths.


