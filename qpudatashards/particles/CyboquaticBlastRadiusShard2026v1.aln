# filename: qpudatashards/particles/CyboquaticBlastRadiusShard2026v1.aln
# destination: eco_restoration_shard/qpudatashards/particles/CyboquaticBlastRadiusShard2026v1.aln

ALN_VERSION 1.0
SCHEMA_NAME cyboquatic.blastradius.shard.2026v1
CATEGORY    ECOSAFETY
DESCRIPTION Cyboquatic industrial machinery blast-radius and workload eco metrics shard.
ALN_SPECHASH_HEX 0xECO2026CYBOQUATICBLASTRADIUSbostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7

PARTICLE CyboquaticBlastRadiusShard2026v1
ROLE     QPUDATASHARD
VERSION  v1
LYAPCHANNEL cyboquatic-machinery

FIELD shard_id        STRING  META   DESCRIPTION "Shard identifier from EcoNet / ecosafety spine."
FIELD machine_id      STRING  META   DESCRIPTION "Cyboquatic machine identifier."
FIELD node_id         STRING  META   DESCRIPTION "Primary node affected by this shard."
FIELD region          STRING  META   DESCRIPTION "Region label, e.g., Phoenix-AZ."
FIELD lane            STRING  META   DESCRIPTION "Lane: RESEARCH, EXPPROD, PROD."

FIELD max_node_radius     F64   RISKCOORD DESCRIPTION "Normalized blast-radius on nodes (0..1)."
FIELD max_material_radius F64   RISKCOORD DESCRIPTION "Normalized blast-radius on materials (0..1)."
FIELD max_carbon_radius   F64   RISKCOORD DESCRIPTION "Normalized carbon blast-radius (0..1)."
FIELD max_biodiv_radius   F64   RISKCOORD DESCRIPTION "Normalized biodiversity blast-radius (0..1)."
FIELD vt_radius_sum       F64   METRIC    DESCRIPTION "Aggregate ΔV_t footprint over blast surface."

FIELD total_req_j     F64   METRIC    DESCRIPTION "Total requested energy in window (J)."
FIELD total_surplus_j F64   METRIC    DESCRIPTION "Total surplus energy in window (J)."
FIELD mean_vt_before  F64   METRIC    DESCRIPTION "Mean Lyapunov residual before workloads."
FIELD mean_vt_after   F64   METRIC    DESCRIPTION "Mean Lyapunov residual after workloads."
FIELD delta_vt        F64   RISKCOORD DESCRIPTION "ΔV_t = mean_vt_after - mean_vt_before."
FIELD mean_r_carbon   F64   RISKCOORD DESCRIPTION "Mean carbon risk coordinate (0..1)."
FIELD mean_r_biodiv   F64   RISKCOORD DESCRIPTION "Mean biodiversity risk coordinate (0..1)."
FIELD accept_fraction F64   METRIC    DESCRIPTION "Accepted fraction of workloads in window."

FIELD created_utc     DATETIME META   DESCRIPTION "Shard creation timestamp."
FIELD evidence_hex    STRING   META   DESCRIPTION "Hex-encoded evidence chain."
FIELD signing_hex     STRING   META   DESCRIPTION "Hex signature bound to Bostrom DID."
FIELD signing_did     STRING   META   DESCRIPTION "Bostrom DID (e.g., bostrom18...)."

ENDPARTICLE

CORRIDOR_VAR delta_vt
LYAPCHANNEL cyboquatic-machinery
SAFE  0.00
GOLD  0.05
HARD  0.10
WEIGHT 1.00
MANDATORY TRUE
ENDCORRIDOR_VAR

CORRIDOR_VAR max_carbon_radius
LYAPCHANNEL cyboquatic-machinery
SAFE  0.00
GOLD  0.30
HARD  0.60
WEIGHT 0.8
MANDATORY TRUE
ENDCORRIDOR_VAR

CORRIDOR_VAR max_biodiv_radius
LYAPCHANNEL cyboquatic-machinery
SAFE  0.00
GOLD  0.25
HARD  0.50
WEIGHT 0.8
MANDATORY TRUE
ENDCORRIDOR_VAR
