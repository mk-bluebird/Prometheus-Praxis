alnversion 1.0
schema CyboquaticPhoenixTurbineWL01_2026v1
title PHX-CANAL-NODE-WL-01 turbine ecosafety shard
region Phoenix-CAP-Canal
nodeid PHX-CANAL-NODE-WL-01
kernelversion KER-2026-04
evidencehex 0xa1b2c3d4e5f67890f1e2d3c4b5a69788
bostromdid bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7

# Core time and identity fields
field shardid String
field tstart String   # ISO8601
field tend   String   # ISO8601

# Energy plane (reuse existing pattern)
field esurplusj   Float
field pmarginkw   Float
field dEdtw       Float

# Hydraulics plane (canal + turbine)
field qm3s        Float         # canal discharge Q
field hlrmperh    Float         # hydraulic loading rate HLR
field rsurcharge  Float         # normalized 0..1
field rcavitation Float         # 0..1 cavitation risk
field roverpressure Float       # 0..1 overpressure / surge
field renergy_hydraulic Float   # 0..1 hydraulic efficiency risk

# Turbine microhydraulics and shear
field headm            Float    # local head at turbine
field vtip_ms          Float    # blade tip speed
field shear_tau_pa     Float    # local shear stress
field delta_p_pa       Float    # pressure drop across rotor
field lethality_index  Float    # L(vtip, tau, delta_p)
field rfishshear       Float    # 0..1 shear lethality risk

# Ramp and turbulence habitat dynamics
field ramp_rate_du_dt  Float    # max |du/dt| over ramp
field turbulence_I     Float    # turbulence intensity u'/ubar
field rramp            Float    # 0..1 ramp risk
field rturbulence      Float    # 0..1 turbulence risk
field rhabitat         Float    # 0..1 habitat damage coordinate

# Biodiversity and pathogen planes (reuse kernel)
field connectivity_index   Float
field structural_complexity Float
field colonization_score   Float
field rbiodiversity        Float     # 0..1
field rpathogen            Float     # 0..1

# Global RiskVector coordinates for turbine workload
field renergy       Float
field rhydraulics   Float
field rbiology      Float
field rcarbon       Float
field rmaterials    Float
field rbiodiversity_coord Float  # duplicate for clarity
field rsigma        Float

# Lyapunov residual and KER window scores
field vt            Float
field kwindow       Float
field ewindow       Float
field rwindow       Float
field lane          String   # RESEARCH | EXP | PROD

# Provenance and signing
field evidencehex   String
field signinghex    String

# Corridor tables referenced by this shard
corridortable PhoenixCanalHydraulics2026v1
corridortable PhoenixTurbineFishShear2026v1
corridortable PhoenixTurbineRampTurbulence2026v1
corridortable PhoenixBiodiversity2026v1
corridortable PhoenixPathogen2026v1

# Admissibility rules (structural sanity)
admissibilityrules
  qm3s          >= 0.0
  hlrmperh      >= 0.0
  headm         >= 0.0
  vtip_ms       >= 0.0
  shear_tau_pa  >= 0.0
  delta_p_pa    >= 0.0
  ramp_rate_du_dt >= 0.0
  turbulence_I  >= 0.0
  0.0 <= rsurcharge <= 1.0
  0.0 <= rcavitation <= 1.0
  0.0 <= roverpressure <= 1.0
  0.0 <= renergy_hydraulic <= 1.0
  0.0 <= rfishshear <= 1.0
  0.0 <= rramp <= 1.0
  0.0 <= rturbulence <= 1.0
  0.0 <= rhabitat <= 1.0
  0.0 <= rbiodiversity <= 1.0
  0.0 <= rpathogen <= 1.0
  0.0 <= renergy <= 1.0
  0.0 <= rhydraulics <= 1.0
  0.0 <= rbiology <= 1.0
  0.0 <= rcarbon <= 1.0
  0.0 <= rmaterials <= 1.0
  0.0 <= rbiodiversity_coord <= 1.0
  0.0 <= rsigma <= 1.0
  nonanall
endadmissibilityrules

# Risk mappings: physical → normalized coordinates
riskmapping rsurcharge_map
  sourcecolumns qm3s, hlrmperh
  targetcoordinate rsurcharge
  corridortable PhoenixCanalHydraulics2026v1
endriskmapping

riskmapping fishshear_map
  sourcecolumns vtip_ms, shear_tau_pa, delta_p_pa
  targetcoordinate rfishshear
  corridortable PhoenixTurbineFishShear2026v1
endriskmapping

riskmapping ramp_map
  sourcecolumn ramp_rate_du_dt
  targetcoordinate rramp
  corridortable PhoenixTurbineRampTurbulence2026v1
endriskmapping

riskmapping turbulence_map
  sourcecolumn turbulence_I
  targetcoordinate rturbulence
  corridortable PhoenixTurbineRampTurbulence2026v1
endriskmapping

riskmapping biodiversity_map
  sourcecolumns connectivity_index, structural_complexity, colonization_score
  targetcoordinate rbiodiversity
  corridortable PhoenixBiodiversity2026v1
endriskmapping

riskmapping pathogen_map
  sourcecolumn rpathogen   # already a biology risk index from assays
  targetcoordinate rbiology
  corridortable PhoenixPathogen2026v1
endriskmapping

# Aggregate hydraulic and habitat coordinates are computed in Rust
riskmapping hydraulics_aggregate
  derivedinrust cyboquatic-ecosafety-hydroturbine::aggregate_hydraulics
  targetcoordinate rhydraulics
endriskmapping

riskmapping habitat_aggregate
  derivedinrust cyboquatic-ecosafety-hydroturbine::aggregate_habitat
  targetcoordinate rbiology
endriskmapping

# KER window scoring derived from residual series
riskmapping ker_window
  derivedinrust cyboquatic-ecosafety-core::KerWindow::fromresidualseries
  targetcoordinates kwindow, ewindow, rwindow
endriskmapping

# Invariants: no-corridor-no-build and safestep
constraint TurbineCorridorPresence
  require rsurcharge   <= 1.0
  require rfishshear   <= 1.0
  require rhabitat     <= 1.0
  require rbiodiversity <= 1.0
  require rpathogen    <= 1.0
  require rsigma       <= 1.0
endconstraint

constraint TurbineGoldBandHydraulics
  # Turbine must remain below gold band for surcharge at all operating points.
  require rsurcharge   <= PhoenixCanalHydraulics2026v1.goldmax
endconstraint

constraint TurbineGoldBandFishShear
  require rfishshear   <= PhoenixTurbineFishShear2026v1.goldmax
endconstraint

constraint TurbineGoldBandHabitat
  require rhabitat     <= PhoenixTurbineRampTurbulence2026v1.goldmax
endconstraint

constraint TurbinePathogenBlock
  # Reject workloads that increase pathogen risk beyond gold bands, even if energy improves.
  require rpathogen    <= PhoenixPathogen2026v1.goldmax
endconstraint

constraint SafeStepAndKER
  # Global safestep and production eligibility.
  require vt >= 0.0
  require kwindow >= 0.90
  require ewindow >= 0.90
  require rwindow <= 0.13
endconstraint

ecoimpactscores
  knowledgefactor 0.95
  ecoimpact       0.92
  residualrisk    0.12
endecoimpactscores

endschema
