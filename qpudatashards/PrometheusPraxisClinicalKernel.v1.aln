aln
title Prometheus-Praxis ClinicalKernel Registry Shard v1
version 1
alnmigration ALN.MIGRATION.CYBERCOREAUTHORITY.v1

binding.hostdid        did:aln:organic-host
binding.bostromaddress bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7

# ---------------------------------------------------------------------------
# References
# ---------------------------------------------------------------------------

ref.neurorightsenvelope neurorights.envelope.citizen.v1
ref.equalityenvelope    equality.envelope.paymentandaccess.v1
ref.soi_cregistry       soic.registry.clinicalkernels.v1

# Prometheus-Praxis core invariants (mirrored for validator compatibility).
invariant.rohglobalceiling       0.3
invariant.monotoneota            true
invariant.noactuationfields      torque,current,stimpattern,autopilot

# ---------------------------------------------------------------------------
# ClinicalKernel registry schema
# ---------------------------------------------------------------------------

# One row per evidence-backed clinical protocol or nanoswarm kernel
# that Panacea-Logos and Prometheus-Praxis are allowed to use at runtime.
# This is a registry of protocols, not direct actuator commands.

type ClinicalKernelRow

field.kernelid             string    # kernel identifier (unique within registry)
field.version              string    # semantic version tag, e.g., "1.0.0"
field.ownerid              string    # DID of clinical authority / institution
field.contextclass         string    # e.g., "BCI-Rehab", "Nanoswarm-Detox", "XR-Therapy"
field.riskclass            string    # e.g., "Low", "Moderate", "High"
field.rohbudget            Bounded01 # per-session risk-of-harm budget
field.capabilityfloor      Bounded01 # minimum capability floor
field.evidencehex          string    # hash of clinical evidence bundle
field.neurorightsenvref    ref       # ref.neurorightsenvelope
field.psychcontinuityreq   bool      # must pass PsychologicalContinuityGate if true
field.soi_cref             string    # SOIC entry id for this kernel
field.validfrom_utc        string    # ISO-8601 UTC activation time
field.validuntil_utc       string    # ISO-8601 UTC expiry time
field.status               string    # "Proposed","Active","Retired","Revoked"
field.tcreatedutc          string    # ISO-8601 UTC creation time
field.tupdatedutc          string    # ISO-8601 UTC last update time

# ---------------------------------------------------------------------------
# Invariants
# ---------------------------------------------------------------------------

# RoH budget cannot exceed the global RoH ceiling from core shard.
invariant.rohbudget_leq_rohglobalceiling true

# Capability floor must not be below the global capability floor reference.
invariant.capabilityfloor_geq_globalfloor true

# High-risk kernels must require psychological continuity gating.
invariant.highrisk_requires_psychcontinuityreq true

# Status must be one of the allowed values.
invariant.status_enum true
invariant.status_values Proposed,Active,Retired,Revoked

# Kernels may not be used outside their validity window.
invariant.validity_window_enforced true

# No actuation fields are permitted in this shard.
invariant.noactuationfields torque,current,stimpattern,autopilot

# ---------------------------------------------------------------------------
# Logging behavior and append-only semantics
# ---------------------------------------------------------------------------

# Kernel registry is logically append-preferred:
# - New versions should be inserted as new rows.
# - Existing rows may be updated to change status or validity window,
#   but kernelid + version must remain immutable.

logging.appendpreferred                 true
logging.mutability.allow_update_fields  status,validfrom_utc,validuntil_utc,tupdatedutc
logging.mutability.forbid_delete        true

# Link to Veritas-Chain for anchoring registry changes.
logging.veritaschainref veritas-chain.v1

# Hex commitment configuration for evidencehex.
logging.hexcommitment.fields          evidencehex
logging.hexcommitment.canonical_json  true
logging.hexcommitment.lowercase_hex   true
