aln psychrisk.roh.bio.alpha.calibration.v1

record RoHBioAlphaProtocolV1
  string protocolid                     # e.g., roh.bio.alpha.he-sgd.v1
  string version                        # semantic version, e.g., 1.0.0
  string ownerdid                       # Bostrom / DID of Cybercore authority
  string jurisdiction                   # US-AZ, EU-DE, Global, etc.
  string domain                         # Clinical, Rehab, AugCitizen, RnD
  string description

  # Link into your existing RoH calibration standard.
  string rohcalibrationprotocolid       # -> psychrisk.roh.calibration.protocol.v1
  float rohflooradult                   # generalized adult floor, e.g., 0.30
  float rohglobalceiling                # must be 0.30 in this space

  # Axes weights must stay normalized ~1.0 as in RoHCalibrationProtocolV1.
  float physloadweight
  float cogloadweight
  float envriskweight
  float devstressweight

  # Personalized alpha learning envelope.
  float alphamin                        # lower bound allowed for alpha
  float alphamax                        # upper bound allowed for alpha
  float alphaadultdefault               # default adult alpha before personalisation

  # Learning configuration (non-actuating, HE/federated only).
  string helibrary                      # homomorphic backend identifier
  string heoptimizer                    # e.g., "he-sgd"
  uint32 maxroundsperday               # training rounds per host per day
  uint32 minhostsperaggregation        # privacy floor
  bool   forbidrawgradientexport       # must be true
  bool   forbidhighresolutiontimestamps
  bool   forbidcrossdevicejoins

  # Evidence and ethics.
  string evidencebundleid               # -> cyberswarm.evidence.bundle.v1
  string ethicsboardref                 # IRB / neurorights board
  string standardid                     # external mapping if any
  string notes
end

record RoHBioAlphaHostBindingV1
  string bindingid                      # unique per host/protocol
  string protocolid                     # -> RoHBioAlphaProtocolV1.protocolid
  string citizenid                      # host DID / Bostrom tuple
  string hostid                         # host-node / Jetson / nanoswarm controller
  string rohcalibrationprotocolid       # repeat for safety
  float rohflooradult
  float rohglobalceiling

  # Learned alpha and confidence band (dimensionless 0..1).
  float alphavalue
  float alphalowerci
  float alphaupperci

  # Governance and invariants.
  bool invariantnotweakerthanadult     # must be true in valid shards
  bool invariantrohfloorpreserved      # must be true in valid shards
  bool invariantpsychriskfloorok       # must be true in valid shards

  string evidencebundleid              # calibration + training evidence
  string notes
end

constraints
  # Global RoH and adult floor invariants.
  RoHBioAlphaProtocolV1.rohglobalceiling 0.30
  RoHBioAlphaProtocolV1.rohflooradult    0.0
  RoHBioAlphaProtocolV1.rohflooradult    0.30

  # Psychrisk axis weights ~1.0 total (same pattern as calibration protocol).
  RoHBioAlphaProtocolV1.physloadweight
    RoHBioAlphaProtocolV1.cogloadweight
    RoHBioAlphaProtocolV1.envriskweight
    RoHBioAlphaProtocolV1.devstressweight 0.99
  RoHBioAlphaProtocolV1.physloadweight
    RoHBioAlphaProtocolV1.cogloadweight
    RoHBioAlphaProtocolV1.envriskweight
    RoHBioAlphaProtocolV1.devstressweight 1.01

  # Alpha bounds must be sane and monotone.
  RoHBioAlphaProtocolV1.alphamin 0.0
  RoHBioAlphaProtocolV1.alphamax 0.0
  RoHBioAlphaProtocolV1.alphamax 4.0
  RoHBioAlphaProtocolV1.alphamin RoHBioAlphaProtocolV1.alphaadultdefault
  RoHBioAlphaProtocolV1.alphaadultdefault RoHBioAlphaProtocolV1.alphamax

  # HE / privacy invariants.
  RoHBioAlphaProtocolV1.forbidrawgradientexport true
  RoHBioAlphaProtocolV1.forbidhighresolutiontimestamps true
  RoHBioAlphaProtocolV1.minhostsperaggregation 8

  # Host bindings: learned alpha must be within protocol bounds.
  RoHBioAlphaHostBindingV1.alphavalue
    RoHBioAlphaProtocolV1.alphamin
  RoHBioAlphaHostBindingV1.alphavalue
    RoHBioAlphaProtocolV1.alphamax

  RoHBioAlphaHostBindingV1.alphalowerci
    RoHBioAlphaProtocolV1.alphamin
  RoHBioAlphaHostBindingV1.alphaupperci
    RoHBioAlphaProtocolV1.alphamax

  RoHBioAlphaHostBindingV1.alphalowerci
    RoHBioAlphaHostBindingV1.alphaupperci

  # No binding may weaken RoH floor or psychrisk floor.
  RoHBioAlphaHostBindingV1.invariantnotweakerthanadult true
  RoHBioAlphaHostBindingV1.invariantrohfloorpreserved true
  RoHBioAlphaHostBindingV1.invariantpsychriskfloorok  true
end
