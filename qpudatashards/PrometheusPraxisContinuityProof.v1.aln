aln
title Prometheus-Praxis ContinuityProof Log Shard v1
version 1
alnmigration ALN.MIGRATION.CYBERCOREAUTHORITY.v1

binding.hostdid        did:aln:organic-host
binding.bostromaddress bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7

# ---------------------------------------------------------------------------
# References
# ---------------------------------------------------------------------------

ref.neurorightsenvelope neurorights.envelope.citizen.v1
ref.equalityenvelope    equality.envelope.paymentandaccess.v1

# Prometheus-Praxis core invariants (mirrored for validator compatibility).
invariant.rohglobalceiling       0.3
invariant.monotoneota            true
invariant.noactuationfields      torque,current,stimpattern,autopilot

# ---------------------------------------------------------------------------
# ContinuityProof log schema
# ---------------------------------------------------------------------------

# One row per continuity-relevant decision, upgrade, or clinical step.
# This shard is append-only: no DELETE, no UPDATE of immutable fields.
# Any corrections are recorded as new rows linked via parent_proofid.

type ContinuityProofRow

field.proofid              string   # primary key at application layer
field.subjectid            string   # DID of citizen / patient / augmented host
field.contextid            string   # workflow / procedure / corridor identifier
field.decisionid           string   # PrometheusPraxisDecision.decisionid
field.epoch                uint64   # continuity epoch, monotone per subjectid
field.proofrefhex          string   # hash of formal continuity proof artifact
field.neurorightsenvref    ref      # ref.neurorightsenvelope
field.equalityenvref       ref      # ref.equalityenvelope
field.kvector              string   # encoded knowledge-factor vector for this step
field.rvector              string   # encoded risk-of-harm vector for this step
field.capabilityfloor      Bounded01
field.parent_proofid       string   # optional; empty string if none
field.timestamputc         string   # ISO-8601 UTC string

# ---------------------------------------------------------------------------
# Invariants
# ---------------------------------------------------------------------------

# Epoch must be non-decreasing per subjectid.
invariant.epoch_monotone_per_subjectid true

# Capability floor must be non-decreasing per subjectid.
invariant.capabilityfloor_monotone_per_subjectid true

# Capability floor must not drop below a global capability floor reference.
# The concrete value is loaded from capability.floor.global.v1, referenced
# in the core Prometheus-Praxis shard.
invariant.capabilityfloor_geq_globalfloor true

# Risk-of-harm vector must respect the global RoH ceiling.
invariant.rvector_leq_rohglobalceiling true

# No actuation fields are permitted; this is a log shard only.
invariant.noactuationfields torque,current,stimpattern,autopilot

# ---------------------------------------------------------------------------
# Logging behavior and append-only semantics
# ---------------------------------------------------------------------------

# Validators and runtime must treat this shard as append-only.
# - INSERT allowed.
# - UPDATE allowed only for fields explicitly marked mutable (none here).
# - DELETE forbidden.

logging.appendonly                      true
logging.mutability.allow_update_fields  none
logging.mutability.forbid_delete        true

# Link to Veritas-Chain for anchoring continuity proofs.
logging.veritaschainref veritas-chain.v1

# Hex commitment configuration for proofrefhex and k/r vectors.
logging.hexcommitment.fields proofrefhex,kvector,rvector
logging.hexcommitment.canonical_json   true
logging.hexcommitment.lowercase_hex    true
