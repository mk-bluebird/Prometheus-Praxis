# path: qpudatashards/cyboquatic/cyboquatic.machinery.ecoblast.2026v1.aln
# repo: github.com/mk-bluebird/eco_restoration_shard

ALN_VERSION 1.0
SCHEMA_NAME cyboquatic.machinery.ecoblast.2026v1
CATEGORY    ECOSAFETY
DESCRIPTION Cyboquatic industrial machinery blast-radius and eco-efficiency shard.
ALN.MIGRATION ALN.MIGRATION.CYBERCOREAUTHORITY.v1
BINDING.HOSTDID   did:aln:organic-host
BINDING.BOSTROM   bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7

RECORD cybo.MachineryEcoBlast.v1
    FIELD machine_id           STRING
    FIELD kind                 STRING
    FIELD region               STRING
    FIELD lane                 STRING
    FIELD max_node_radius      F64
    FIELD max_region_radius    F64
    FIELD max_energy_radius    F64
    FIELD max_carbon_radius    F64
    FIELD max_biodiv_radius    F64
    FIELD vt_radius_sum        F64
    FIELD total_e_req_j        F64
    FIELD total_e_used_j       F64
    FIELD total_carbon_kg      F64
    FIELD total_pollutant_kg   F64
    FIELD mean_vt_before       F64
    FIELD mean_vt_after        F64
    FIELD delta_vt             F64
    FIELD mean_roh_scalar      F64
    FIELD pollutant_per_kj     F64
    FIELD accept_fraction      F64
ENDRECORD

INVARIANT cybo.MachineryEcoBlast.delta_vt.nonpositive
    FORALL m IN cybo.MachineryEcoBlast.v1
        m.delta_vt <= 0.10
ENDINVARIANT

INVARIANT cybo.MachineryEcoBlast.roh.lane.ceiling
    FORALL m IN cybo.MachineryEcoBlast.v1
        m.mean_roh_scalar <= 0.30
ENDINVARIANT

INVARIANT cybo.MachineryEcoBlast.carbon.blast.bound
    FORALL m IN cybo.MachineryEcoBlast.v1
        m.max_carbon_radius <= 0.60
ENDINVARIANT
