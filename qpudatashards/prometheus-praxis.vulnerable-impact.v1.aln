aln
aln.title Prometheus-Praxis Vulnerable-Impact Contract v1
version 1.0.0

aln.migration ALN.MIGRATION.CYBERCOREAUTHORITY.v1
binding.hostdid didalnorganic-host
binding.bostromaddress bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7

; --------------------------------------------------------------------------
; 1. Core enums: domains, lanes, vulnerable-impact class
; --------------------------------------------------------------------------

enum vulnerable.ActionDomain.v1
  EcoRestoration
  CityOperations
  MacroHealth
  Cybernetics
  PaymentGovernance
end

enum vulnerable.ActionLane.v1
  Research
  Pilot
  Production
end

; EU AI Act Article 9: high-risk AI, vulnerable persons, safety and rights.
enum vulnerable.ImpactClass.v1
  None               ; no identified vulnerable-group coupling
  VulnerablePersons  ; minors, elderly, disabled, socio-economically fragile
  HealthCritical     ; direct health, clinical, subsurface-health consequences
  NeuroSensitive     ; BCI, somatic-coupled, psych-risk
end

; --------------------------------------------------------------------------
; 2. Vulnerable-impact envelope: binds KER/RoH to Article 9 & neurorights
; --------------------------------------------------------------------------

record vulnerable.ImpactEnvelope.v1
  id                 Uuid

  domain             vulnerable.ActionDomain.v1
  lane               vulnerable.ActionLane.v1
  impactclass        vulnerable.ImpactClass.v1

  ; KER targets for this vulnerable class and lane (0..1)
  kmin               f32
  emin               f32
  rmax               f32

  ; Global and local RoH ceilings (Article 9 high-risk safety floor)
  rohceilingglobal   f32        ; must match ecosafety global, e.g. 0.30
  rohceilinglocal    f32        ; optional stricter per-domain ceiling

  ; Neurorights / PSAT bindings
  psatprofileid      String     ; ieee-p7007 profile ID when NeuroSensitive
  neurorightsenvelopeid String  ; ALN shard id for neurorights envelope

  ; EU AI Act Article 9 mapping metadata
  euaiarticle        String     ; e.g. "Art.9 High-Risk / Vulnerable Persons"
  riskmanagementplan String     ; reference id to risk management ALN shard
  datagovernanceplan String     ; reference id to data governance ALN shard

  createdutc         String
end

; --------------------------------------------------------------------------
; 3. Vulnerable-impact snapshot per action (Rust MacroActionContext binding)
; --------------------------------------------------------------------------

record vulnerable.ImpactSnapshot.v1
  id                 Uuid
  actionid           String          ; MacroActionContext.actionid
  domain             vulnerable.ActionDomain.v1
  lane               vulnerable.ActionLane.v1
  impactclass        vulnerable.ImpactClass.v1

  ; KER actuals (0..1) for this action
  kactual            f32
  eactual            f32
  ractual            f32

  ; RoH actual scalar (0..1)
  rohactual          f32

  ; Rights-risk scalar Q, Article 9 vulnerable-persons coupling
  rightsriskq        f32
  rightsriskqcrit    f32

  ; Flags for EU AI Act Annex III / Art. 9 risk status
  highriskflag       bool
  vulnerablepersonsflag bool
  healthcriticalflag bool
  neurosensitiveflag bool

  ; Provenance references
  envelopeid         Uuid           ; vulnerable.ImpactEnvelope.v1.id
  veritasanchorid    String         ; Veritas-Chain shard
  janusverifierid    String         ; Janus-Veritas check id

  createdutc         String
end

; --------------------------------------------------------------------------
; 4. Invariants: KER lanes, global RoH ceiling, Article 9 rights gates
; --------------------------------------------------------------------------

; 4.1 Global RoH ceiling non-offsettable (matches Praxis/Rights kernels).
invariant vulnerable.GlobalRohCeiling
  forall env in vulnerable.ImpactEnvelope.v1
    env.rohceilingglobal <= 0.30
end

; 4.2 Lane KER thresholds structurally consistent with RoH and lane.
invariant vulnerable.LaneKerConsistency
  forall env in vulnerable.ImpactEnvelope.v1
    env.kmin  >= 0.0
    env.emin  >= 0.0
    env.rmax  >= 0.0
    env.rmax  <= env.rohceilinglocal or env.rmax <= env.rohceilingglobal
end

; 4.3 Vulnerable-persons and neuro-sensitive lanes require PSAT & neurorights.
invariant vulnerable.PsatAndNeurorightsRequired
  forall env in vulnerable.ImpactEnvelope.v1
    (env.impactclass == vulnerable.ImpactClass.v1.VulnerablePersons
     or env.impactclass == vulnerable.ImpactClass.v1.NeuroSensitive
     or env.impactclass == vulnerable.ImpactClass.v1.HealthCritical)
    implies env.psatprofileid != ""
         and env.neurorightsenvelopeid != ""
end

; 4.4 High-risk / vulnerable actions cannot exceed RoH ceiling regardless of K,E.
invariant vulnerable.HighRiskMustRespectRohCeiling
  forall snap in vulnerable.ImpactSnapshot.v1, env in vulnerable.ImpactEnvelope.v1
    snap.envelopeid == env.id
    and snap.highriskflag == true
    implies snap.rohactual <= env.rohceilingglobal
           and snap.rohactual <= env.rohceilinglocal
end

; 4.5 Rights-risk scalar Q: vulnerable-persons must Stop when Q >= Qcrit.
invariant vulnerable.RightsRiskStopsOnCritical
  forall snap in vulnerable.ImpactSnapshot.v1
    snap.vulnerablepersonsflag == true
    and snap.rightsriskq >= snap.rightsriskqcrit
    implies snap.highriskflag == true
end

; 4.6 Monotone safety: lane upgrades must not worsen R, RoH, or rights-risk.
record vulnerable.LaneTransition.v1
  id                 Uuid
  actionid           String
  fromlane           vulnerable.ActionLane.v1
  tolane             vulnerable.ActionLane.v1
  fromimpactclass    vulnerable.ImpactClass.v1
  toimpactclass      vulnerable.ImpactClass.v1
  fromr              f32
  tor                f32
  fromroh            f32
  toroh              f32
  fromrightsriskq    f32
  torightsriskq      f32
  emergencyrecordref String   ; optional emergency ALN record
end

invariant vulnerable.LaneTransitionMonotoneSafety
  forall t in vulnerable.LaneTransition.v1
    ; Normal evolution: equal or safer for R, RoH, rights-risk.
    (t.tor   <= t.fromr
     and t.toroh <= t.fromroh
     and t.torightsriskq <= t.fromrightsriskq)
    or
    ; Any regression must be explicitly marked as emergency.
    (t.emergencyrecordref != "")
end

end
