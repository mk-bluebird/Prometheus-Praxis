-----------------------------------------------------------------------
Rules: enforce nonactuating diagnostics in this catalog
-----------------------------------------------------------------------

rule workloadwindow_functions_nonactuating
  when f ppx.function.meta.v1
  then require f.nonactuating == true
       else error PPX_WORKLOADWINDOW_FUNCTION_MUST_BE_NONACTUATING
