aln
alnversion 1.0.0
alnnamespace prometheus.praxis.functioncatalog.workloadwindow.v1

-----------------------------------------------------------------------
Language and function meta particles
-----------------------------------------------------------------------

particle language.v1
  name str.v1       -- LUA | RUST | KOTLIN | SQL | ALN

particle ppx.function.meta.v1
  id koid.v1
  label str.v1
  language language.v1
  modulepath str.v1      -- e.g. "crates/ecosafety-nanoswarm-urban-core/src/workload_window.rs"
  entrypoint str.v1      -- e.g. "list_workload_node_windows"
  nonactuating bool.v1
  ecosafetyguardrequired bool.v1
  neurorightsguardrequired bool.v1
  inputschemaid koid.v1
  outputschemaid koid.v1
  kerhintk f32.v1
  kerhinte f32.v1
  kerhintr f32.v1

-----------------------------------------------------------------------
Input / output schemas aligned with SQL and ALN particles
-----------------------------------------------------------------------

particle ecosafety.workload.window.list.input.v1
  id koid.v1
  shardid str.v1?       -- optional filter
  nodeid str.v1?        -- optional filter
  assetid str.v1?       -- optional filter
  window_start_utc_min time.timestamp.v1?
  window_end_utc_max   time.timestamp.v1?

particle ecosafety.workload.window.summary.input.v1
  id koid.v1
  nodeid str.v1
  window_start_utc time.timestamp.v1
  window_end_utc   time.timestamp.v1

particle ecosafety.workload.window.summary.output.v1
  id koid.v1
  nodeid str.v1
  window_count u32.v1
  mean_energy_req_j f64.v1
  mean_energy_surplus_j f64.v1
  mean_accepted_fraction f64.v1
  mean_rejected_fraction f64.v1
  mean_rerouted_fraction f64.v1
  mean_vt_before f64.v1
  mean_vt_after  f64.v1
  mean_delta_vt  f64.v1
  hard_violation_count u32.v1
  soft_violation_count u32.v1

-----------------------------------------------------------------------
Function entries (Rust and Lua, nonactuating, diagnostic-only)
